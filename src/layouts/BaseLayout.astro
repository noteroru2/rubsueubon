---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileStickyCTA from '../components/MobileStickyCTA.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  keywords?: string[];
  jsonLd?: Record<string, unknown>[];
  showMobileCTA?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage,
  ogType,
  noindex,
  keywords,
  jsonLd,
  showMobileCTA = false,
} = Astro.props;
---

<!doctype html>
<html lang="th">
  <head>
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
      keywords={keywords}
      jsonLd={jsonLd}
    />
  </head>
  <body
    class:list={[
      'min-h-screen flex flex-col bg-surface text-ink antialiased',
      (showMobileCTA || Astro.slots.has('mobile-cta')) && 'pb-[4.5rem] md:pb-0',
    ]}
  >
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:rounded-lg focus:bg-brand focus:px-4 focus:py-2 focus:text-white"
    >
      ข้ามไปเนื้อหาหลัก
    </a>
    <Header />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
    {showMobileCTA ? <MobileStickyCTA /> : <slot name="mobile-cta" />}
  </body>
</html>
