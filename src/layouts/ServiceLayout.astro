---
import BaseLayout from './BaseLayout.astro';
import { buildFAQPageSchema } from '../lib/schema';

export interface Props {
  frontmatter: {
    title: string;
    description: string;
    category: string;
    faqs?: { question: string; answer: string }[];
  };
  canonical?: string;
  ogImage?: string;
  featuredImage?: string;
  keywords?: string[];
  jsonLd?: Record<string, unknown>[];
}

const LINE_URL = 'https://line.me/R/ti/p/@buyhub';

const { frontmatter, canonical, ogImage, featuredImage, keywords, jsonLd = [] } = Astro.props;
const { title, description, faqs } = frontmatter;

const schemaScripts: Record<string, unknown>[] = [...jsonLd];

if (faqs && faqs.length > 0) {
  schemaScripts.push(buildFAQPageSchema(faqs));
}

const trustSignals = [
  { icon: '💵', label: 'รับซื้อด้วยเงินสด' },
  { icon: '⚖️', label: 'ให้ราคายุติธรรม' },
  { icon: '⚡', label: 'ประเมินราคาไวใน 5 นาที' },
];

const steps = [
  { number: '1', title: 'ส่งรูปและสเปค', description: 'ถ่ายรูปสินค้า แจ้งรุ่นและสภาพ ส่งมาที่ LINE @buyhub' },
  { number: '2', title: 'ประเมินราคา', description: 'รับใบเสนอราคาฟรีภายใน 5 นาที ไม่มีข้อผูกมัด' },
  { number: '3', title: 'นัดรับของและรับเงินสด', description: 'ตกลงราคาแล้วนัดรับในอุบลราชธานี จ่ายเงินสดทันที' },
];
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  ogType="article"
  keywords={keywords}
  jsonLd={schemaScripts}
>
  <!-- Hero -->
  <section
    class="relative overflow-hidden bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white"
    aria-labelledby="service-hero-heading"
  >
    <div class="pointer-events-none absolute inset-0 opacity-30" aria-hidden="true">
      <div class="absolute -right-16 -top-16 h-64 w-64 rounded-full bg-[#00B900]/20 blur-3xl"></div>
    </div>

    <div class="relative mx-auto max-w-5xl px-4 py-14 sm:px-6 sm:py-20">
      <div class={`grid gap-8 items-center ${featuredImage ? 'lg:grid-cols-2' : ''}`}>
        <div class={featuredImage ? 'max-w-xl' : 'max-w-2xl'}>
          <p
            class="inline-flex items-center rounded-full bg-white/10 px-3 py-1 text-sm font-medium ring-1 ring-white/20"
          >
            อุบลราชธานี · รับซื้อ-รับเทิร์นไอที
          </p>
          <h1 id="service-hero-heading" class="mt-5 text-2xl font-extrabold leading-tight sm:text-3xl lg:text-4xl">
            {title}
          </h1>
          <p class="mt-4 text-base leading-relaxed text-white/85 sm:text-lg">
            {description}
          </p>
          <a
            href={LINE_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-8 inline-flex w-full items-center justify-center gap-2 rounded-full bg-[#00B900] px-6 py-3.5 text-base font-bold text-white shadow-lg transition hover:bg-[#009900] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#00B900] sm:w-auto"
          >
            <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"
              ></path>
            </svg>
            แอด LINE ประเมินราคาฟรีทันที
          </a>
        </div>
        {
          featuredImage && (
            <div class="hidden lg:flex justify-center items-center">
              <img
                src={featuredImage}
                alt={title}
                width="480"
                height="320"
                loading="eager"
                decoding="async"
                class="max-h-72 w-full rounded-2xl object-cover shadow-2xl ring-1 ring-white/10"
              />
            </div>
          )
        }
      </div>
    </div>
  </section>

  <!-- Trust Signals -->
  <section class="border-b border-line bg-surface-alt py-8 sm:py-10" aria-label="จุดเด่นที่ลูกค้าไว้วางใจ">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <ul class="grid grid-cols-1 gap-4 sm:grid-cols-3">
        {
          trustSignals.map((signal) => (
            <li class="flex items-center gap-3 rounded-xl border border-line bg-surface px-4 py-3 shadow-sm">
              <span class="text-xl" aria-hidden="true">
                {signal.icon}
              </span>
              <span class="text-sm font-semibold text-ink">{signal.label}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-12 sm:py-14" aria-labelledby="how-it-works-heading">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <h2 id="how-it-works-heading" class="text-xl font-bold text-ink sm:text-2xl">ขั้นตอนการขายง่ายๆ</h2>
      <p class="mt-2 text-sm text-muted">รับซื้อและรับเทิร์นไอทีในอุบลราชธานี — จบใน 3 ขั้นตอน</p>
      <ol class="mt-8 grid gap-4 sm:grid-cols-3">
        {
          steps.map((step) => (
            <li class="rounded-2xl border border-line bg-surface p-5 shadow-sm">
              <span
                class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-[#00B900]/10 text-sm font-bold text-[#00B900]"
                aria-hidden="true"
              >
                {step.number}
              </span>
              <h3 class="mt-3 font-bold text-ink">{step.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-muted">{step.description}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- Main Content -->
  <section class="border-t border-line bg-surface-alt py-12 sm:py-14">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      {
        featuredImage && (
          <div class="mb-10 lg:hidden">
            <img
              src={featuredImage}
              alt={title}
              width="800"
              height="450"
              loading="lazy"
              decoding="async"
              class="w-full rounded-2xl object-cover shadow-md"
            />
          </div>
        )
      }
      <article
        class="prose prose-lg mx-auto max-w-none prose-headings:font-bold prose-headings:text-ink prose-p:text-muted prose-strong:text-ink prose-a:text-brand prose-a:no-underline hover:prose-a:underline prose-li:text-muted prose-ul:marker:text-brand"
      >
        <slot />
      </article>
    </div>
  </section>

  <!-- Map Section -->
  <section class="border-t border-line bg-surface py-12 sm:py-14" aria-labelledby="map-heading">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <h2 id="map-heading" class="text-center text-xl font-bold text-ink sm:text-2xl">
        พิกัดร้านรับซื้อในจังหวัดอุบลราชธานี
      </h2>
      <p class="mt-2 text-center text-sm text-muted">
        เดินทางสะดวก มีหน้าร้านชัดเจน หรือจะเรียกใช้บริการรับถึงที่ก็ยินดีครับ
      </p>
      <div class="mt-8 overflow-hidden rounded-2xl border border-line shadow-sm">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3849.025200608903!2d104.844358!3d15.266421499999996!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x311687b7ef0583c9%3A0x90ad9a37b84af3a!2z4Lit4Liz4Lie4LilIOC5gOC4l-C4o-C4lOC4lOC4tOC5ieC4hyAtIOC4o-C4seC4muC4i-C4t-C5ieC4rSDguILguLLguKIg4LiL4LmI4Lit4LihIOC4hOC4reC4oeC4nuC4tOC4p-C5gOC4leC4reC4o-C5jCDguKHguLfguK3guJbguLfguK0g4LiB4Lil4LmJ4Lit4LiHIOC4peC4s-C5guC4nuC4hyDguKrguLTguJnguITguYnguLLguYTguK3guJfguLXguJfguLjguIHguIrguJnguLTguJQ!5e0!3m2!1sth!2sth!4v1781084191572!5m2!1sth!2sth"
          width="100%"
          height="450"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        >
        </iframe>
        <div class="border-t border-line bg-surface-alt p-4 text-center">
          <a
            href="https://maps.app.goo.gl/uuwGbjpMeedTC1ik8"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-bold text-brand hover:underline"
          >
            📍 นำทางไปหน้าร้าน (Google Maps)
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  {
    faqs && faqs.length > 0 && (
      <section class="py-12 sm:py-14" aria-labelledby="faq-heading">
        <div class="mx-auto max-w-3xl px-4 sm:px-6">
          <h2 id="faq-heading" class="text-xl font-bold text-ink sm:text-2xl">
            คำถามที่พบบ่อย
          </h2>
          <div class="mt-6 space-y-3">
            {faqs.map((faq) => (
              <details class="group rounded-2xl border border-line bg-surface open:border-brand/30 open:shadow-sm">
                <summary class="cursor-pointer list-none px-5 py-4 font-semibold text-ink marker:content-none [&::-webkit-details-marker]:hidden">
                  <span class="flex items-center justify-between gap-4">
                    {faq.question}
                    <span class="shrink-0 text-brand transition group-open:rotate-180" aria-hidden="true">
                      ▼
                    </span>
                  </span>
                </summary>
                <div class="border-t border-line px-5 py-4 text-sm leading-relaxed text-muted">{faq.answer}</div>
              </details>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <slot name="after-content" />

  <!-- Sticky Mobile CTA (forwarded to BaseLayout) -->
  <div
    slot="mobile-cta"
    class="fixed bottom-0 left-0 right-0 z-50 w-full border-t border-line bg-surface/95 p-4 shadow-[0_-4px_20px_rgba(0,0,0,0.1)] backdrop-blur-md md:hidden"
    role="complementary"
    aria-label="ขายด่วนผ่าน LINE"
  >
    <a
      href={LINE_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="flex w-full items-center justify-center gap-2 rounded-full bg-[#00B900] px-4 py-3.5 text-base font-bold text-white shadow-sm transition hover:bg-[#009900] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[#00B900]"
    >
      <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path
          d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"
        ></path>
      </svg>
      ขายด่วน แอดไลน์เลย!
    </a>
  </div>
</BaseLayout>
