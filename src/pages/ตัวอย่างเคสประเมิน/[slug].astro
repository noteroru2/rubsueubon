---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTAButton from '../../components/CTAButton.astro';
import { SITE } from '../../config/site';
import { examplePath, examplesIndex } from '../../config/urls';
import { buildBreadcrumbSchema } from '../../lib/breadcrumbs';

export async function getStaticPaths() {
  const examples = await getCollection('examples');
  return examples.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, disclaimer } = entry.data;

const canonical = examplePath(entry.data.slug);

const breadcrumbItems = [
  { label: 'หน้าแรก', href: '/' },
  { label: 'ตัวอย่างเคสประเมินราคา', href: examplesIndex() },
  { label: title },
];

const jsonLd = [
  buildBreadcrumbSchema(breadcrumbItems),
  {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting', // No AggregateRating/Review per requirement
    headline: title,
    description,
    url: `${SITE.url}${canonical}`,
    inLanguage: 'th-TH',
    publisher: { '@id': `${SITE.url}/#localbusiness` },
  },
];
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogType="article"
  jsonLd={jsonLd}
  showMobileCTA
>
  <article class="py-12 sm:py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <Breadcrumbs items={breadcrumbItems} />
      
      <div class="mt-6 mb-4 p-4 bg-orange-50 border-l-4 border-orange-400 text-orange-800 text-sm font-medium rounded-r-lg">
        <strong>คำชี้แจง:</strong> {disclaimer}
      </div>

      <h1 class="mt-2 text-2xl font-extrabold text-ink sm:text-3xl">{title}</h1>

      <div
        class="prose prose-lg mt-8 max-w-none prose-p:text-muted prose-a:text-brand prose-a:no-underline hover:prose-a:underline"
      >
        <Content />
      </div>

      <div class="mt-10 text-center">
        <CTAButton label="ประเมินราคาฟรีทันที" />
      </div>
    </div>
  </article>
</BaseLayout>
