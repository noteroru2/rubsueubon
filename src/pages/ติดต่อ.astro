---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTAButton from '../components/CTAButton.astro';
import { SITE, getLineOALink } from '../config/site';
import { areaNav, infoNav, serviceNav } from '../config/navigation';
import { areasIndex, contactPage, faqPage, pricingPage, servicesIndex, updatesIndex } from '../config/urls';
import { buildBreadcrumbSchema } from '../lib/breadcrumbs';
import { buildLocalBusinessSchema } from '../lib/schema';

const pageTitle = 'ติดต่อเรา / ประเมินราคาด่วน | รับซื้ออุบล.com';
const pageDescription =
  'ติดต่อรับซื้ออุบล.com เพื่อประเมินราคาฟรี แอด LINE @buyhub หรือดูบริการรับซื้อ-รับเทิร์นไอทีในอุบลราชธานี';

const breadcrumbItems = [
  { label: 'หน้าแรก', href: '/' },
  { label: 'ติดต่อเรา' },
];

const jsonLd = [buildBreadcrumbSchema(breadcrumbItems), buildLocalBusinessSchema()];
const lineLink = getLineOALink();
const mapUrl = `https://www.google.com/maps?q=${SITE.geo.latitude},${SITE.geo.longitude}`;
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={contactPage()} jsonLd={jsonLd} showMobileCTA>
  <div class="py-12 sm:py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <Breadcrumbs items={breadcrumbItems} />
      <h1 class="mt-6 text-2xl font-extrabold text-ink sm:text-3xl">ติดต่อเรา / ประเมินราคาด่วน</h1>
      <p class="mt-4 text-lg text-muted">{pageDescription}</p>

      <div class="mt-8 rounded-2xl bg-gradient-to-r from-brand to-brand-dark p-8 text-center text-white">
        <h2 class="text-xl font-bold">ช่องทางที่เร็วที่สุด — LINE</h2>
        <p class="mt-2 text-white/85">ส่งรูปสินค้า รับใบเสนอราคาฟรีภายใน 5 นาที</p>
        <div class="mt-5">
          <CTAButton href={lineLink} label="แอด LINE @buyhub ประเมินราคาฟรี" />
        </div>
      </div>

      <div class="mt-10 grid gap-6 sm:grid-cols-2">
        <div class="rounded-2xl border border-line p-5">
          <h2 class="font-bold text-ink">ข้อมูลติดต่อ</h2>
          <ul class="mt-3 space-y-2 text-sm text-muted">
            <li><strong class="text-ink">LINE OA:</strong> {SITE.lineOA}</li>
            <li><strong class="text-ink">โทรศัพท์:</strong> {SITE.phone}</li>
            <li><strong class="text-ink">อีเมล:</strong> {SITE.email}</li>
            <li><strong class="text-ink">พื้นที่ให้บริการ:</strong> อุบลราชธานี (10 อำเภอหลัก)</li>
            <li><strong class="text-ink">เวลาให้บริการ:</strong> จันทร์–เสาร์ 09:00–18:00</li>
          </ul>
          <a
            href={mapUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 inline-flex text-sm font-semibold text-brand hover:underline"
          >
            ดูแผนที่อุบลราชธานีบน Google Maps →
          </a>
        </div>
        <div class="rounded-2xl border border-line p-5">
          <h2 class="font-bold text-ink">บริการรับซื้อ</h2>
          <ul class="mt-3 space-y-2 text-sm">
            {serviceNav.map((item) => (
              <li>
                <a href={item.href} class="text-brand hover:underline">{item.label}</a>
              </li>
            ))}
          </ul>
          <p class="mt-4 text-sm">
            <a href={servicesIndex()} class="font-semibold text-brand hover:underline">ดูบริการทั้งหมด →</a>
          </p>
        </div>
      </div>

      <div class="mt-8 rounded-2xl border border-line bg-surface-alt p-5">
        <h2 class="font-bold text-ink">ข้อมูลเพิ่มเติม</h2>
        <ul class="mt-3 flex flex-wrap gap-x-4 gap-y-2 text-sm">
          {infoNav.map((item) => (
            <li>
              <a href={item.href} class="text-brand hover:underline">{item.label}</a>
            </li>
          ))}
          <li>
            <a href={updatesIndex()} class="text-brand hover:underline">ผลงานรับซื้อล่าสุด</a>
          </li>
        </ul>
      </div>

      <div class="mt-8">
        <h2 class="font-bold text-ink">พื้นที่ให้บริการด่วน</h2>
        <p class="mt-2 text-sm text-muted">
          <a href={areasIndex()} class="text-brand hover:underline">ดูพื้นที่ให้บริการทั้งหมด 10 อำเภอ →</a>
        </p>
        <ul class="mt-3 flex flex-wrap gap-2">
          {areaNav.map((item) => (
            <li>
              <a
                href={item.href}
                class="inline-block rounded-full border border-line px-3 py-1.5 text-sm text-muted transition hover:border-brand/30 hover:text-brand"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <article class="prose prose-lg mt-12 max-w-none prose-p:text-muted prose-a:text-brand prose-headings:text-ink">
        <h2>วิธีประเมินราคาผ่าน LINE @buyhub</h2>
        <ol>
          <li>แอด LINE OA <strong>@buyhub</strong> (มี @ นำหน้า)</li>
          <li>ถ่ายรูปสินค้า — หน้าจอ ตัวเครื่องรอบด้าน รอยตำหนิ (ถ้ามี)</li>
          <li>แจ้งรุ่น สเปค และสภาพการใช้งาน</li>
          <li>รับใบเสนอราคาฟรีภายใน 5 นาที</li>
          <li>ตกลงราคา นัดรับสินค้า รับเงินสดทันที</li>
        </ol>
        <p>
          อ่านรายละเอียดเพิ่มเติมที่ <a href={pricingPage()}>วิธีประเมินราคา</a>
          <a href={faqPage()}>คำถามที่พบบ่อย</a>
          หรือดู <a href={updatesIndex()}>ผลงานรับซื้อล่าสุด</a> เพื่อยืนยันความน่าเชื่อถือ
        </p>
        <h2>ทำไมติดต่อเราผ่าน LINE?</h2>
        <ul>
          <li>ตอบเร็ว — รับใบเสนอราคาภายใน 5 นาที</li>
          <li>สะดวก — ส่งรูปได้ทันที ไม่ต้องเดินทาง</li>
          <li>โปร่งใส — แจ้งราคาชัดเจนก่อนนัดรับเสมอ</li>
          <li>ปลอดภัย — นัดรับในที่สาธารณะหรือจุดที่สะดวกทั้งสองฝ่าย</li>
        </ul>
      </article>
    </div>
  </div>
</BaseLayout>
