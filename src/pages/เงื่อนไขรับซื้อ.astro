---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTAButton from '../components/CTAButton.astro';
import FAQSection from '../components/FAQSection.astro';
import { conditionsPage, pricingPage } from '../config/urls';
import { buildBreadcrumbSchema } from '../lib/breadcrumbs';
import { buildFAQPageSchema } from '../lib/schema';
import { conditionFAQs } from '../lib/faqs';

const pageTitle = 'เงื่อนไขรับซื้อ สินค้าไอที อุบลราชธานี | รับซื้ออุบล.com';
const pageDescription =
  'เงื่อนไขการรับซื้อ-รับเทิร์นสินค้าไอทีในอุบลราชธานี สินค้าที่รับซื้อ สินค้าที่ไม่รับ เอกสารที่ต้องใช้ และข้อควรทราบก่อนขาย';

const breadcrumbItems = [{ label: 'หน้าแรก', href: '/' }, { label: 'เงื่อนไขรับซื้อ' }];

const jsonLd = [buildBreadcrumbSchema(breadcrumbItems), buildFAQPageSchema(conditionFAQs)];
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={conditionsPage()} jsonLd={jsonLd} showMobileCTA>
  <div class="py-12 sm:py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <Breadcrumbs items={breadcrumbItems} />
      <h1 class="mt-6 text-2xl font-extrabold text-ink sm:text-3xl">เงื่อนไขการรับซื้อสินค้าไอที</h1>
      <p class="mt-4 text-lg text-muted">{pageDescription}</p>

      <div class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-3">
        <div class="overflow-hidden rounded-xl shadow-sm">
          <img
            src="/images/services/smartphone-iphone-android.webp"
            alt="รับซื้อโทรศัพท์มือถือ iPhone Samsung อุบล"
            width="320"
            height="213"
            loading="eager"
            decoding="async"
            class="h-28 w-full object-cover sm:h-36"
          />
        </div>
        <div class="overflow-hidden rounded-xl shadow-sm">
          <img
            src="/images/services/notebook-ubon.webp"
            alt="รับซื้อโน้ตบุ๊ก MacBook อุบล"
            width="320"
            height="213"
            loading="eager"
            decoding="async"
            class="h-28 w-full object-cover sm:h-36"
          />
        </div>
        <div class="overflow-hidden rounded-xl shadow-sm">
          <img
            src="/images/services/camera-sony-canon-fujifilm.webp"
            alt="รับซื้อกล้อง Sony Canon อุบล"
            width="320"
            height="213"
            loading="eager"
            decoding="async"
            class="h-28 w-full object-cover sm:h-36"
          />
        </div>
        <div class="overflow-hidden rounded-xl shadow-sm">
          <img
            src="/images/services/apple-devices-macbook-imac.webp"
            alt="รับซื้อ Apple MacBook iPad อุบล"
            width="320"
            height="213"
            loading="lazy"
            decoding="async"
            class="h-28 w-full object-cover sm:h-36"
          />
        </div>
        <div class="overflow-hidden rounded-xl shadow-sm">
          <img
            src="/images/services/pc-gaming-desktop.webp"
            alt="รับซื้อ PC Gaming คอมพิวเตอร์ อุบล"
            width="320"
            height="213"
            loading="lazy"
            decoding="async"
            class="h-28 w-full object-cover sm:h-36"
          />
        </div>
        <div class="overflow-hidden rounded-xl shadow-sm">
          <img
            src="/images/services/ipad-tablet.webp"
            alt="รับซื้อ iPad แท็บเล็ต อุบล"
            width="320"
            height="213"
            loading="lazy"
            decoding="async"
            class="h-28 w-full object-cover sm:h-36"
          />
        </div>
      </div>

      <article
        class="prose prose-lg mt-10 max-w-none prose-p:text-muted prose-a:text-brand prose-headings:text-ink prose-li:text-muted"
      >
        <h2>สินค้าไอทีที่รับซื้อในอุบลราชธานี</h2>
        <p>
          เรารับซื้อสินค้าไอทีทุกประเภทที่ยังมีมูลค่าในตลาดมือสอง ทั้งสภาพดีและสภาพมีตำหนิ
          โดยประเมินราคาตามสภาพจริงแบบยุติธรรม
        </p>
        <h3>โทรศัพท์มือถือและแท็บเล็ต</h3>
        <ul>
          <li>iPhone ทุกรุ่น ตั้งแต่ iPhone X ขึ้นไป</li>
          <li>Samsung Galaxy S series, Z series, A series, Note series</li>
          <li>OPPO, vivo, Xiaomi, Realme ทุกรุ่น</li>
          <li>iPad ทุกรุ่น รวมถึง iPad Pro, iPad Air, iPad mini</li>
          <li>แท็บเล็ต Android ยี่ห้ออื่น Samsung Galaxy Tab, Lenovo Tab</li>
        </ul>
        <h3>โน้ตบุ๊กและคอมพิวเตอร์</h3>
        <ul>
          <li>MacBook Air, MacBook Pro ทุก Chip (Intel, M1, M2, M3)</li>
          <li>ASUS, Dell, HP, Lenovo, MSI, Acer, Razer ทุกซีรีส์</li>
          <li>PC Gaming ประกอบเอง และ PC Gaming สำเร็จรูปทุกยี่ห้อ</li>
          <li>อะไหล่คอม — GPU, CPU, RAM, SSD, Motherboard</li>
        </ul>
        <h3>กล้องและอุปกรณ์ถ่ายภาพ</h3>
        <ul>
          <li>กล้อง Mirrorless — Sony, Canon, Nikon, Fujifilm, Panasonic</li>
          <li>กล้อง DSLR ทุกยี่ห้อ</li>
          <li>เลนส์ทุก Mount — FE, RF, Z, X, L, EF</li>
          <li>Action Cam — GoPro, DJI Osmo Action ทุกรุ่น</li>
        </ul>
        <h3>อุปกรณ์ไอทีอื่นๆ</h3>
        <ul>
          <li>Apple Watch และ Smart Watch ยี่ห้ออื่น</li>
          <li>เครื่องเสียง — ลำโพง Bluetooth, หูฟัง Hi-fi</li>
          <li>เครื่องเกม — PlayStation, Nintendo Switch, Xbox</li>
          <li>TV และ Monitor ยี่ห้อ Samsung, LG, Sony ขนาด 32" ขึ้นไป</li>
        </ul>

        <h2>สภาพสินค้าที่รับซื้อ</h2>
        <p>
          เรารับสินค้าหลายสภาพ ไม่จำเป็นต้องสมบูรณ์แบบ แต่สภาพที่ดีกว่าย่อมได้ราคาที่สูงกว่า
          ดังนั้นการเก็บรักษาเครื่องให้ดีมีผลต่อมูลค่า
        </p>
        <ul>
          <li><strong>สภาพดีมาก (Grade A)</strong> — ไม่มีรอยขีดข่วน ใช้งานปกติทุกฟังก์ชัน ได้ราคาดี</li>
          <li><strong>สภาพดี (Grade B)</strong> — มีรอยใช้งานเล็กน้อย หน้าจอและตัวเครื่องยังสมบูรณ์ ได้ราคาดี</li>
          <li><strong>สภาพปานกลาง (Grade C)</strong> — มีรอยขีดข่วนชัดเจน แต่ใช้งานได้ปกติ ราคาต่ำกว่า Grade B</li>
          <li><strong>สภาพเสีย/ชำรุด</strong> — ประเมินราคาตามชิ้นส่วนที่ยังมีมูลค่า เช่น จอแตก เครื่องเปิดไม่ติด</li>
          <li><strong>แบตเตอรี่เสื่อม</strong> — ยังรับซื้อได้ แต่หักราคาตามระดับการเสื่อมของแบต</li>
        </ul>

        <h2>สินค้าที่ไม่รับซื้อ</h2>
        <p>มีสินค้าบางประเภทที่เราไม่สามารถรับซื้อได้ เพื่อป้องกันปัญหาทางกฎหมายและความเสียหายต่อทุกฝ่าย</p>
        <ul>
          <li>
            <strong>เครื่องติด iCloud (Find My iPhone)</strong> — ต้องปลดก่อนเท่านั้น ปลดผ่าน Settings → [ชื่อ] → Sign Out
          </li>
          <li><strong>เครื่องติด Google FRP</strong> — ต้อง Factory Reset และปลด Google Account ก่อน</li>
          <li>
            <strong>เครื่องติดโปรโมชั่นเครือข่ายที่ยังผ่อนไม่ครบ</strong> — เครื่อง True, AIS, DTAC ที่ยังอยู่ในสัญญา
          </li>
          <li><strong>เครื่องที่มีหลักฐานการโจรกรรม</strong> — IMEI ถูกแบล็กลิสต์ หรือเจ้าของรายงานหาย</li>
          <li><strong>อุปกรณ์ที่เสียหายสิ้นเชิง</strong> — เสียหายจากน้ำรุนแรง ไหม้ ไม่มีชิ้นส่วนที่มีมูลค่าเหลือ</li>
        </ul>

        <h2>เอกสารและข้อมูลที่ต้องเตรียม</h2>
        <p>การเตรียมเอกสารให้ครบช่วยให้กระบวนการนัดรับรวดเร็ว และเป็นการยืนยันตัวตนตามกฎหมายไทยที่กำหนด</p>
        <ul>
          <li><strong>บัตรประชาชน</strong> — บังคับ ใช้ยืนยันตัวตนผู้ขายทุกครั้ง</li>
          <li><strong>กล่องและใบเสร็จซื้อ</strong> — ไม่บังคับ แต่อาจเพิ่มราคาได้เล็กน้อย</li>
          <li><strong>อุปกรณ์ที่มาพร้อม</strong> — สายชาร์จ อะแดปเตอร์ หูฟัง ยิ่งครบยิ่งได้ราคาดี</li>
          <li><strong>PIN/Password</strong> — ต้องปลดล็อคหน้าจอให้ตรวจสอบได้ก่อนนัดรับ</li>
        </ul>

        <figure class="not-prose my-8 overflow-hidden rounded-xl shadow-md">
          <img
            src="/images/cash-3d.webp"
            alt="จ่ายเงินสดทันทีขายไอที อุบลราชธานี"
            width="800"
            height="400"
            loading="lazy"
            decoding="async"
            class="w-full object-cover"
          />
          <figcaption class="bg-surface px-4 py-2 text-sm text-muted">
            ตกลงราคาแล้วจ่ายเงินสดทันที ไม่มีการรอโอน
          </figcaption>
        </figure>

        <h2>กระบวนการรับซื้อและนัดรับ</h2>
        <p>ทุกขั้นตอนออกแบบให้ง่ายและรวดเร็วที่สุด สามารถจบกระบวนการตั้งแต่ประเมินราคาจนถึงรับเงินได้ในวันเดียว</p>
        <ol>
          <li><strong>ส่งรูปและรายละเอียดมาที่ LINE @buyhub</strong> — รูปสินค้า 4-6 รูป พร้อมรุ่น สเปค และสภาพ</li>
          <li><strong>รับใบเสนอราคา</strong> — ภายใน 5-15 นาที ราคาชัดเจน ไม่มีข้อผูกมัด</li>
          <li><strong>ตกลงราคาและนัดรับ</strong> — เลือกจุดนัดที่สะดวก ในเขตอุบลราชธานีและอำเภอรอบข้าง</li>
          <li><strong>ตรวจสอบสินค้า</strong> — เราตรวจสอบตามรายการที่แจ้งมา ใช้เวลา 10-20 นาที</li>
          <li><strong>จ่ายเงินสดทันที</strong> — เมื่อสภาพตรงตามที่แจ้ง รับเงินสดได้เลยทันที</li>
        </ol>
        <p>
          อ่านรายละเอียดวิธีประเมินราคาได้ที่ <a href={pricingPage()}>วิธีประเมินราคา</a>
        </p>

        <h2>เงื่อนไขการปรับราคาหน้างาน</h2>
        <p>
          เราให้ความสำคัญกับความโปร่งใส ราคาที่แจ้งผ่าน LINE คือราคาที่ตั้งใจจะจ่ายจริง
          แต่มีกรณีที่อาจจำเป็นต้องปรับราคาหน้างาน ดังนี้
        </p>
        <ul>
          <li>สภาพหน้าจอหรือตัวเครื่องแตกต่างจากรูปที่ส่งมาอย่างมีนัยสำคัญ</li>
          <li>Battery Health ต่ำกว่าที่แจ้งมา เช่น แจ้งว่า 85% แต่จริงๆ 72%</li>
          <li>ฟังก์ชันบางอย่างเสียที่ไม่ได้แจ้งล่วงหน้า เช่น กล้องเสีย ลำโพงเสีย</li>
          <li>เครื่องยังติด Account ที่ยังปลดไม่ออก ณ เวลานัดรับ</li>
        </ul>
        <p>
          ทุกกรณีเราจะแจ้งเหตุผลและราคาที่ปรับอย่างชัดเจนก่อน ไม่มีการปรับราคาโดยไม่มีเหตุผล
          ลูกค้ามีสิทธิ์ปฏิเสธและนำสินค้ากลับได้ทุกเมื่อก่อนตกลงราคาสุดท้าย
        </p>

        <h2>นโยบายความเป็นส่วนตัวและข้อมูลผู้ขาย</h2>
        <p>
          ข้อมูลส่วนตัวของผู้ขาย รวมถึงเลขบัตรประชาชนและข้อมูลการซื้อขาย
          จะถูกเก็บรักษาอย่างปลอดภัยและไม่เปิดเผยแก่บุคคลที่สาม นอกจากในกรณีที่กฎหมายบังคับ เช่น
          การร้องขอจากเจ้าหน้าที่ตำรวจ อ่านรายละเอียดเพิ่มเติมได้ที่ <a href="/นโยบายความเป็นส่วนตัว"
            >นโยบายความเป็นส่วนตัว</a
          >
        </p>

        <h2>คำถามที่พบบ่อยเกี่ยวกับเงื่อนไขรับซื้อ</h2>
        <p>
          หากมีข้อสงสัยเพิ่มเติมนอกเหนือจากที่ระบุไว้ สามารถถามตรงผ่าน LINE ได้ทันที
          ทีมงานพร้อมตอบคำถามและช่วยประเมินราคาทุกวัน สำหรับคำถามทั่วไปเกี่ยวกับบริการ อ่านเพิ่มเติมได้ที่ <a
            href="/คำถามที่พบบ่อย">คำถามที่พบบ่อย</a
          >
        </p>

        <h2>พื้นที่บริการรับซื้อในอุบลราชธานี</h2>
        <p>
          เราให้บริการรับซื้อไอทีครอบคลุมทุกอำเภอในจังหวัดอุบลราชธานี ทั้งในตัวเมืองอุบลราชธานี วารินชำราบ พิบูลมังสาหาร
          เดชอุดม ม่วงสามสิบ ตระการพืชผล นาจะหลวย สิรินธร สำโรง และขุนหาญ
          นอกจากนี้ยังให้บริการนอกพื้นที่กรณีสินค้าราคาสูง
        </p>
        <p>
          ดูรายละเอียดพื้นที่บริการและจุดนัดรับแต่ละอำเภอได้ที่ <a href="/พื้นที่">พื้นที่ให้บริการ</a>
        </p>
      </article>

      <div class="mt-12">
        <FAQSection faqs={conditionFAQs} title="คำถามเกี่ยวกับเงื่อนไข" />
      </div>

      <div class="mt-10 text-center">
        <CTAButton label="สอบถามเงื่อนไขผ่าน LINE" />
      </div>
    </div>
  </div>
</BaseLayout>
