---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, getLineOALink } from '../config/site';

const pageTitle = `ไม่พบหน้าที่ต้องการ (404) | ${SITE.name}`;
const description = 'ขออภัย ไม่พบหน้าที่คุณกำลังค้นหา อาจถูกลบไปแล้วหรือพิมพ์ URL ผิดพลาด';
const lineLink = getLineOALink();
---

<BaseLayout title={pageTitle} description={description} showMobileCTA>
  <section
    class="relative flex min-h-[70vh] flex-col items-center justify-center overflow-hidden bg-gradient-to-br from-brand via-brand-dark to-ink px-4 py-20 text-center text-white"
  >
    <div class="pointer-events-none absolute inset-0 opacity-20" aria-hidden="true">
      <div class="absolute -right-20 -top-20 h-72 w-72 rounded-full bg-white/20 blur-3xl"></div>
      <div class="absolute -bottom-24 -left-16 h-64 w-64 rounded-full bg-line/30 blur-3xl"></div>
    </div>

    <div class="relative z-10 max-w-2xl">
      <p class="mb-4 text-sm font-semibold tracking-widest text-white/70 uppercase">Error 404</p>
      <h1 class="mb-6 text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl">ไม่พบหน้าที่ต้องการ</h1>
      <p class="mb-10 text-lg leading-relaxed text-white/80 sm:text-xl">
        ขออภัยค่ะ หน้าที่คุณกำลังค้นหาอาจถูกลบ ย้ายที่อยู่ หรือไม่มีอยู่บนระบบของเรา<br class="hidden sm:block" />
        หากต้องการประเมินราคาสินค้าไอที สามารถติดต่อเราทาง LINE ได้เลยค่ะ
      </p>

      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="/"
          class="inline-flex w-full items-center justify-center rounded-full bg-white px-6 py-3.5 text-base font-semibold text-ink shadow-sm transition hover:bg-surface-alt sm:w-auto"
        >
          ← กลับหน้าแรก
        </a>
        <a
          href={lineLink}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex w-full items-center justify-center gap-2 rounded-full bg-line px-6 py-3.5 text-base font-semibold text-white shadow-sm transition hover:bg-line-dark sm:w-auto"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"
            ></path>
          </svg>
          แอดไลน์ @buyhub
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
