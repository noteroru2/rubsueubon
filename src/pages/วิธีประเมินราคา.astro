---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTAButton from '../components/CTAButton.astro';
import FAQSection from '../components/FAQSection.astro';
import { conditionsPage, pricingPage } from '../config/urls';
import { buildBreadcrumbSchema } from '../lib/breadcrumbs';
import { buildFAQPageSchema } from '../lib/schema';
import { pricingFAQs } from '../lib/faqs';

const pageTitle = 'วิธีประเมินราคา รับซื้อไอที อุบลราชธานี | รับซื้ออุบล.com';
const pageDescription =
  'วิธีประเมินราคารับซื้อไอทีในอุบลราชธานี ปัจจัยที่กำหนดราคา สิ่งที่ต้องเตรียมก่อนส่งรูป และขั้นตอนรับเงินสดทันทีผ่าน LINE @buyhub';

const breadcrumbItems = [
  { label: 'หน้าแรก', href: '/' },
  { label: 'วิธีประเมินราคา' },
];

const jsonLd = [buildBreadcrumbSchema(breadcrumbItems), buildFAQPageSchema(pricingFAQs)];
---

<BaseLayout title={pageTitle} description={pageDescription} canonical={pricingPage()} jsonLd={jsonLd} showMobileCTA>
  <div class="py-12 sm:py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <Breadcrumbs items={breadcrumbItems} />
      <h1 class="mt-6 text-2xl font-extrabold text-ink sm:text-3xl">วิธีประเมินราคารับซื้อไอที</h1>
      <p class="mt-4 text-lg text-muted">{pageDescription}</p>

      <div class="mt-8 overflow-hidden rounded-2xl shadow-md">
        <img
          src="/images/cash-3d.jpg"
          alt="รับเงินสดทันทีขายไอที อุบลราชธานี รับซื้ออุบล.com"
          width="800"
          height="400"
          loading="eager"
          decoding="async"
          class="w-full object-cover"
        />
      </div>

      <article class="prose prose-lg mt-10 max-w-none prose-p:text-muted prose-a:text-brand prose-headings:text-ink prose-li:text-muted">
        <h2>ขั้นตอนการประเมินราคาไอทีมือสอง</h2>
        <p>
          กระบวนการประเมินราคาทั้งหมดออกแบบให้ทำผ่านออนไลน์ ไม่ต้องเดินทางมาร้าน ไม่ต้องรอคิว
          เริ่มต้นได้ทันทีจากโทรศัพท์มือถือหรือคอมพิวเตอร์
        </p>
        <ol>
          <li><strong>ถ่ายรูปสินค้า</strong> — หน้าจอเปิดอยู่ ตัวเครื่องรอบด้าน รอยตำหนิ (ถ้ามี) อย่างน้อย 4-6 รูป</li>
          <li><strong>แจ้งรายละเอียด</strong> — รุ่น สเปค ความจุ สภาพแบตเตอรี่ และอุปกรณ์ที่มาพร้อม</li>
          <li><strong>แอด LINE @buyhub</strong> — ส่งรูปและรายละเอียดมาในแชทได้เลย ฟรี</li>
          <li><strong>รับใบเสนอราคา</strong> — ภายใน 5 นาที ไม่มีข้อผูกมัด ไม่มีค่าธรรมเนียม</li>
          <li><strong>นัดรับและรับเงิน</strong> — ตกลงราคาแล้วนัดรับในอุบลราชธานี จ่ายเงินสดทันที</li>
        </ol>

        <figure class="not-prose my-8 overflow-hidden rounded-xl shadow-md">
          <img
            src="/images/services/smartphone-iphone-android.webp"
            alt="รับซื้อโทรศัพท์มือถือ iPhone Android อุบลราชธานี"
            width="800"
            height="450"
            loading="lazy"
            decoding="async"
            class="w-full object-cover"
          />
          <figcaption class="bg-surface px-4 py-2 text-sm text-muted">รับซื้อ iPhone, Samsung, OPPO และสมาร์ทโฟนทุกยี่ห้อในอุบลราชธานี</figcaption>
        </figure>

        <h2>ปัจจัยที่กำหนดราคารับซื้อโทรศัพท์มือถือ</h2>
        <p>
          ราคารับซื้อสมาร์ทโฟนขึ้นอยู่กับหลายปัจจัยที่เราพิจารณาควบคู่กัน
          การเข้าใจปัจจัยเหล่านี้จะช่วยให้คาดเดาราคาได้ล่วงหน้าและเตรียมข้อมูลได้ครบถ้วน
        </p>
        <h3>iPhone และ iOS Devices</h3>
        <ul>
          <li>รุ่นและความจุ — iPhone 15 Pro Max 256GB ได้ราคาสูงกว่า iPhone 13 64GB มาก</li>
          <li>Battery Health — แบตต่ำกว่า 80% ลดราคาพอสมควร ดูได้จาก Settings › Battery › Battery Health</li>
          <li>สภาพหน้าจอและตัวเครื่อง — จอแตกหรือมีรอยลึกกระทบราคาสูง</li>
          <li>iCloud ต้องปลดก่อนขาย — เครื่องที่ยังติด Find My ไม่รับซื้อ</li>
        </ul>
        <h3>Android (Samsung OPPO vivo Xiaomi)</h3>
        <ul>
          <li>ยี่ห้อและซีรีส์ — Samsung Galaxy S/Z series ได้ราคาดีกว่า A series</li>
          <li>สเปค RAM/Storage — 12GB/256GB ได้ราคาดีกว่า 6GB/128GB</li>
          <li>Google Account ต้องปลดก่อนขาย และทำ Factory Reset ก่อนส่งมอบ</li>
        </ul>

        <figure class="not-prose my-8 overflow-hidden rounded-xl shadow-md">
          <img
            src="/images/services/notebook-ubon.webp"
            alt="รับซื้อโน้ตบุ๊ก MacBook ASUS Dell อุบลราชธานี"
            width="800"
            height="450"
            loading="lazy"
            decoding="async"
            class="w-full object-cover"
          />
          <figcaption class="bg-surface px-4 py-2 text-sm text-muted">รับซื้อโน้ตบุ๊กทุกยี่ห้อ MacBook, ASUS, Dell, HP, Lenovo ในอุบลราชธานี</figcaption>
        </figure>

        <h2>ปัจจัยที่กำหนดราคารับซื้อโน้ตบุ๊ก</h2>
        <p>
          ราคารับซื้อโน้ตบุ๊กมือสองซับซ้อนกว่าสมาร์ทโฟน เพราะมีองค์ประกอบมากกว่า
          ยิ่งแจ้งรายละเอียดสเปคครบ ยิ่งได้ราคาประเมินที่แม่นยำขึ้น
        </p>
        <ul>
          <li>ยี่ห้อและซีรีส์ — MacBook M3 ได้ราคาดีกว่า Windows สเปคใกล้เคียง</li>
          <li>CPU, RAM, SSD — i9/Ryzen 9 ได้ราคาดีกว่า i5/Ryzen 5 อย่างเห็นได้ชัด</li>
          <li>การ์ดจอ — GPU Dedicated RTX/RX ได้ราคาสูงกว่า Integrated Graphics</li>
          <li>Cycle Count แบตเตอรี่ (สำหรับ MacBook) — ดูจาก System Information › Power</li>
          <li>สภาพหน้าจอ คีย์บอร์ด และตัวเครื่อง — รอยขีดข่วน บุบ กระทบราคา</li>
        </ul>

        <figure class="not-prose my-8 overflow-hidden rounded-xl shadow-md">
          <img
            src="/images/services/camera-sony-canon-fujifilm.webp"
            alt="รับซื้อกล้อง Sony Canon Fujifilm อุบลราชธานี"
            width="800"
            height="450"
            loading="lazy"
            decoding="async"
            class="w-full object-cover"
          />
          <figcaption class="bg-surface px-4 py-2 text-sm text-muted">รับซื้อกล้อง Mirrorless, DSLR และเลนส์ทุก Mount ในอุบลราชธานี</figcaption>
        </figure>

        <h2>ปัจจัยที่กำหนดราคารับซื้อกล้องและเลนส์</h2>
        <p>
          กล้องมือสองมีปัจจัยเฉพาะทางที่ต้องพิจารณาเพิ่มเติมจากสภาพภายนอก
          โดยเฉพาะจำนวนชัตเตอร์และสภาพเซนเซอร์ที่กระทบมูลค่าโดยตรง
        </p>
        <h3>ตัวกล้อง</h3>
        <ul>
          <li>Shutter Count (จำนวนชัตเตอร์) — ต่ำกว่า 50,000 ครั้งถือว่าดีมาก ดูได้จาก camerashuttercount.com</li>
          <li>ยี่ห้อและรุ่น — Sony A7IV, Canon R6 II ได้ราคาดีกว่ารุ่นเก่า</li>
          <li>สภาพเซนเซอร์ — ฝุ่น Hotpixel มีผลต่อราคา</li>
          <li>สภาพช่อง EVF และ LCD — EVF มีจุด LCD มีรอยลดราคา</li>
        </ul>
        <h3>เลนส์</h3>
        <ul>
          <li>ยี่ห้อและ Mount — Sony G Master FE-mount ได้ราคาดีกว่า Third-party</li>
          <li>สภาพแก้วเลนส์ — รา หมอก รอยขีดข่วนบนแก้วลดราคามาก</li>
          <li>โฟกัสและ Aperture — ทำงานได้ปกติทุก f-stop</li>
        </ul>

        <h2>สิ่งที่ต้องเตรียมก่อนส่งรูปประเมิน</h2>
        <p>
          การเตรียมรูปและข้อมูลให้ครบถ้วนก่อนส่งมาที่ LINE จะช่วยให้ได้ราคาประเมินที่แม่นยำ
          และลดโอกาสที่ราคาจะต้องปรับเปลี่ยนหน้างาน
        </p>
        <ul>
          <li>ถ่ายรูปในที่แสงเพียงพอ ให้เห็นรายละเอียดชัดเจน ไม่ใช้แฟลชโดยตรงที่ทำให้เห็นรอยไม่ชัด</li>
          <li>เปิดหน้าจอแสดงรุ่นและสเปค Settings → About (iPhone) หรือ System Information (Mac)</li>
          <li>ถ่ายรูปสุขภาพแบตเตอรี่ (Battery Health)</li>
          <li>ถ่ายรอยตำหนิทุกจุด ไม่ปิดบัง เพราะหากสภาพต่างจากที่แจ้งอาจต้องปรับราคา</li>
          <li>แจ้งอุปกรณ์ที่มาพร้อมครบถ้วน เช่น กล่อง สายชาร์จ อะแดปเตอร์</li>
        </ul>

        <h2>ทำไมราคารับซื้อต่างจากราคาขายปลีก?</h2>
        <p>
          ราคารับซื้อจะต่ำกว่าราคาขายปลีกเสมอ เพราะผู้รับซื้อต้องมีต้นทุนในการตรวจสอบคุณภาพ
          จัดเก็บ และขายต่อในตลาดมือสอง ซึ่งต้องใช้เวลาและต้นทุน
        </p>
        <p>
          เราให้ราคาที่ยุติธรรมตามสภาพจริงและราคาตลาดอุบลราชธานีปัจจุบัน
          ไม่กดราคาหลังนัดรับ ราคาที่แจ้งผ่าน LINE คือราคาที่ได้รับจริงเมื่อส่งสินค้า
          อ่าน <a href={conditionsPage()}>เงื่อนไขรับซื้อ</a> เพิ่มเติมได้
        </p>

        <h2>วิธีเตรียม iPhone และ Android ก่อนขาย</h2>
        <p>
          การเตรียมเครื่องให้พร้อมก่อนนัดรับช่วยให้กระบวนการรวดเร็วขึ้น
          และป้องกันความล่าช้าที่อาจเกิดขึ้นหากต้องปลดล็อคหน้างาน
        </p>
        <h3>iPhone</h3>
        <p>
          Sign Out จาก iCloud: Settings → [ชื่อ] → Sign Out จากนั้นทำ Factory Reset:
          Settings → General → Transfer or Reset iPhone → Erase All Content and Settings
          ตรวจสอบว่า Find My iPhone ปิดแล้ว ก่อนส่งมอบ
        </p>
        <h3>Android</h3>
        <p>
          Sign Out จาก Google Account และ Samsung Account (ถ้าใช้ Samsung)
          จากนั้นทำ Factory Reset จาก Settings → General Management → Reset
          ตรวจสอบว่าปิด Google FRP (Factory Reset Protection) แล้วก่อนส่งมอบ
        </p>

        <h2>ราคาประเมินผ่าน LINE ถูกต้องแน่นอนไหม?</h2>
        <p>
          ราคาที่แจ้งผ่าน LINE เป็นราคาที่เราตั้งใจจะจ่ายจริง ไม่ใช่ราคาเบื้องต้นที่จะมาปรับลดหน้างาน
          หากสภาพสินค้าตรงกับที่แจ้งมาทุกประการ ราคาจะไม่เปลี่ยนแปลง
        </p>
        <p>
          กรณีที่ราคาอาจถูกปรับ คือเมื่อสภาพจริงแตกต่างจากที่แจ้งมาอย่างมีนัยสำคัญ เช่น
          แจ้งว่าจอปกติแต่พบรอยแตกเมื่อนัดรับ หรือแจ้งสุขภาพแบตผิด
          เราจะแจ้งเหตุผลและราคาที่ปรับชัดเจน ไม่มีการปรับโดยไม่มีเหตุผล
        </p>

        <h2>การประเมินราคาไอทีมือสองอื่นๆ</h2>
        <p>
          นอกจากสมาร์ทโฟน โน้ตบุ๊ก และกล้อง เรายังรับซื้อไอทีหลายประเภทในอุบลราชธานี
          แต่ละประเภทมีวิธีประเมินเฉพาะทาง
        </p>
        <h4>Apple Watch และ Smart Watch</h4>
        <p>ดูจาก Battery Health ใน Watch app, Shutter Count ไม่มีผล แต่สภาพตัวเรือนและกระจกสำคัญมาก Unpair จาก iPhone ก่อนส่งมอบ</p>
        <h4>PC Gaming และการ์ดจอ</h4>
        <p>ส่งรายการสเปคครบ GPU CPU RAM SSD และรูปเครื่อง ราคาขึ้นอยู่กับสเปคและสภาพการใช้งาน การ์ดที่เคยขุดเหมืองต้องแจ้งล่วงหน้า</p>
        <h4>กล้อง Mirrorless</h4>
        <p>ตรวจสอบ Shutter Count จาก camerashuttercount.com ก่อน และถ่ายรูปทดสอบ f/16 เพื่อดูฝุ่นบนเซนเซอร์ส่งมาพร้อมด้วย</p>
      </article>

      <div class="mt-12">
        <FAQSection faqs={pricingFAQs} title="คำถามเกี่ยวกับราคา" />
      </div>

      <div class="mt-10 text-center">
        <CTAButton label="ส่งรูปประเมินราคาฟรีทันที" />
      </div>
    </div>
  </div>
</BaseLayout>
