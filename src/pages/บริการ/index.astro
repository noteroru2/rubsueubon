---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTAButton from '../../components/CTAButton.astro';
import { getCollection } from 'astro:content';
import { aboutPage, areasIndex, faqPage, pricingPage, servicePath, updatesIndex } from '../../config/urls';
import { buildBreadcrumbSchema } from '../../lib/breadcrumbs';

const allServices = (await getCollection('services')).sort((a, b) => a.data.order - b.data.order);
const mainServices = allServices.filter((s) => s.data.tier === 'main');
const brandServices = allServices.filter((s) => s.data.tier === 'brand');

const pageTitle = 'บริการรับซื้อ-รับเทิร์นไอที อุบลราชธานี | รับซื้ออุบล.com';
const pageDescription =
  'บริการรับซื้อโทรศัพท์มือถือ โน้ตบุ๊ก กล้อง และรับเทิร์นสินค้าไอทีในอุบลราชธานี ประเมินราคาฟรี จ่ายเงินสดทันที';

const breadcrumbItems = [
  { label: 'หน้าแรก', href: '/' },
  { label: 'บริการรับซื้อ' },
];

const jsonLd = [buildBreadcrumbSchema(breadcrumbItems)];
---

<BaseLayout title={pageTitle} description={pageDescription} jsonLd={jsonLd} showMobileCTA>
  <div class="py-12 sm:py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <Breadcrumbs items={breadcrumbItems} />
      <h1 class="mt-6 text-2xl font-extrabold text-ink sm:text-3xl">
        บริการรับซื้อ-รับเทิร์นไอที อุบลราชธานี
      </h1>
      <p class="mt-4 text-lg text-muted">{pageDescription}</p>

      <div class="prose prose-lg mt-8 max-w-none prose-p:text-muted prose-a:text-brand prose-headings:text-ink">
        <p>
          เลือกหมวดสินค้าที่ต้องการขาย เรารับซื้อและรับเทิร์นสินค้าไอทีมือหนึ่ง-มือสองทุกยี่ห้อในอุบลราชธานี
          ประเมินราคาฟรีผ่าน LINE <strong>@buyhub</strong> จ่ายเงินสดทันที ไม่มีค่าธรรมเนียมแอบแฝง
        </p>
        <p>
          ไม่ว่าคุณจะอยู่เมืองอุบล วารินชำราบ เดชอุดม หรืออำเภออื่น เรานัดรับถึงที่ได้
          ดู <a href={areasIndex()}>พื้นที่ให้บริการ</a> ทั้งหมด อ่าน <a href={aboutPage()}>เกี่ยวกับเรา</a>,
          <a href={pricingPage()}>วิธีประเมินราคา</a> หรือ <a href={updatesIndex()}>ผลงานรับซื้อล่าสุด</a>
        </p>

        <h2>บริการรับซื้อไอทีที่เราให้บริการ</h2>
        <p>
          รับซื้ออุบล.com เป็นศูนย์รวมการรับซื้อและรับเทิร์นสินค้าไอทีในจังหวัดอุบลราชธานี
          ครอบคลุมทั้งโทรศัพท์มือถือ โน้ตบุ๊ก กล้องถ่ายภาพ และบริการเทิร์นหลายชิ้นพร้อมกัน
          เราตีราคาตามสภาพจริงและราคาตลาดปัจจุบัน ไม่กดราคาหลังนัดรับ
        </p>

        <h2>ขั้นตอนการขาย-เทิร์นกับเรา</h2>
        <ol>
          <li>ถ่ายรูปสินค้าและแจ้งรุ่น สภาพ และอุปกรณ์ที่มี</li>
          <li>แอด LINE <strong>@buyhub</strong> ส่งรูปเพื่อรับใบเสนอราคาฟรีภายใน 5 นาที</li>
          <li>ตกลงราคา นัดรับสินค้า (ถึงที่หรือจุดนัดที่สะดวก) จ่ายเงินสดทันที</li>
        </ol>

        <h2>ทำไมลูกค้าในอุบลเลือกเรา</h2>
        <ul>
          <li>ให้ราคายุติธรรม โปร่งใส ไม่มีค่าใช้จ่ายแอบแฝง</li>
          <li>รับซื้อหลายสภาพ รวมเครื่องที่ร้านอื่นอาจไม่รับ</li>
          <li>นัดรับครอบคลุม 10 อำเภอหลักในอุบลราชธานี</li>
          <li>รับซื้อหลายชิ้นจบในที่เดียว — มือถือ โน้ตบุ๊ก กล้องพร้อมกันได้</li>
        </ul>
        <p>
          มีคำถาม? อ่าน <a href={faqPage()}>คำถามที่พบบ่อย</a>
        </p>
      </div>

      <h2 class="mt-10 text-lg font-bold text-ink">บริการหลัก</h2>
      <ul class="mt-4 grid gap-6 sm:grid-cols-2">
        {
          mainServices.map((service) => (
            <li>
              <a
                href={servicePath(service.data.slug)}
                class="group flex h-full flex-col rounded-2xl border border-line bg-surface p-6 shadow-sm transition hover:border-brand/30 hover:shadow-md"
              >
                <h3 class="text-lg font-bold text-ink group-hover:text-brand">{service.data.title}</h3>
                <p class="mt-2 flex-1 text-sm leading-relaxed text-muted">{service.data.description}</p>
                <span class="mt-4 text-sm font-semibold text-brand">ดูรายละเอียด →</span>
              </a>
            </li>
          ))
        }
      </ul>

      <h2 class="mt-12 text-lg font-bold text-ink">บริการตามแบรนด์ยอดนิยม</h2>
      <p class="mt-2 text-sm text-muted">หน้าเฉพาะทางสำหรับแบรนด์ที่ลูกค้าค้นหาบ่อย</p>
      <ul class="mt-4 grid gap-4 sm:grid-cols-2">
        {
          brandServices.map((service) => (
            <li>
              <a
                href={servicePath(service.data.slug)}
                class="group flex h-full flex-col rounded-2xl border border-line bg-surface p-5 shadow-sm transition hover:border-brand/30 hover:shadow-md"
              >
                <h3 class="font-bold text-ink group-hover:text-brand">{service.data.navLabel}</h3>
                <p class="mt-2 flex-1 text-sm text-muted line-clamp-2">{service.data.description}</p>
                <span class="mt-3 text-sm font-semibold text-brand">ดูรายละเอียด →</span>
              </a>
            </li>
          ))
        }
      </ul>

      <div class="mt-10 text-center">
        <CTAButton label="แอด LINE ประเมินราคาฟรีทันที" />
      </div>
    </div>
  </div>
</BaseLayout>
