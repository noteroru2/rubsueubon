---
import { getCollection, render } from 'astro:content';
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ConditionsScope from '../../components/ConditionsScope.astro';
import GeoServiceLinks from '../../components/GeoServiceLinks.astro';
import { SITE } from '../../config/site';
import { servicePath, servicesIndex, updatePath, updatesIndex } from '../../config/urls';
import { buildBreadcrumbSchema } from '../../lib/breadcrumbs';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const {
  title,
  description,
  category,
  navLabel,
  geoLinkLabel,
  keywords,
  featuredImage,
  acceptedConditions,
  rejectedConditions,
  faqs,
  tier,
  parentSlug,
  parentLabel,
} = entry.data;

const canonical = servicePath(entry.data.slug);
const ogImage = featuredImage
  ? new URL(featuredImage, SITE.url).href
  : `${SITE.url}/og-default.svg`;

const relatedUpdates = (await getCollection('updates'))
  .filter((u) => u.data.relatedServiceSlug === entry.id)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const breadcrumbItems =
  tier === 'brand' && parentSlug && parentLabel
    ? [
        { label: 'หน้าแรก', href: '/' },
        { label: 'บริการรับซื้อ', href: servicesIndex() },
        { label: parentLabel, href: servicePath(parentSlug) },
        { label: navLabel },
      ]
    : [
        { label: 'หน้าแรก', href: '/' },
        { label: 'บริการรับซื้อ', href: servicesIndex() },
        { label: navLabel },
      ];

const jsonLd = [
  buildBreadcrumbSchema(breadcrumbItems),
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': `${SITE.url}${canonical}#webpage`,
    url: `${SITE.url}${canonical}`,
    name: title,
    description,
    inLanguage: 'th-TH',
    isPartOf: { '@id': `${SITE.url}/#website` },
    about: { '@id': `${SITE.url}/#localbusiness` },
  },
];
---

<ServiceLayout
  frontmatter={{ title, description, category, faqs }}
  canonical={canonical}
  ogImage={ogImage}
  featuredImage={featuredImage}
  keywords={keywords}
  jsonLd={jsonLd}
>
  <div class="not-prose mb-8">
    <Breadcrumbs items={breadcrumbItems} />
  </div>
  <Content />

  <div slot="after-content">
    {
      (acceptedConditions.length > 0 || rejectedConditions.length > 0) && (
        <ConditionsScope accepted={acceptedConditions} rejected={rejectedConditions} />
      )
    }
    {
      relatedUpdates.length > 0 && (
        <section class="py-12 sm:py-14" aria-labelledby="related-updates-heading">
          <div class="mx-auto max-w-6xl px-4 sm:px-6">
            <h2 id="related-updates-heading" class="text-xl font-bold text-ink sm:text-2xl">
              ผลงานรับซื้อที่เกี่ยวข้อง
            </h2>
            <ul class="mt-6 grid gap-4 sm:grid-cols-3">
              {relatedUpdates.map((post) => (
                <li>
                  <a
                    href={updatePath(post.data.slug)}
                    class="block rounded-2xl border border-line bg-surface p-4 transition hover:border-brand/30 hover:shadow-md"
                  >
                    <p class="font-semibold text-ink hover:text-brand">{post.data.title}</p>
                    <p class="mt-2 text-sm text-muted line-clamp-2">{post.data.description}</p>
                  </a>
                </li>
              ))}
            </ul>
            <p class="mt-4 text-sm">
              <a href={updatesIndex()} class="font-semibold text-brand hover:underline">
                ดูผลงานทั้งหมด →
              </a>
            </p>
          </div>
        </section>
      )
    }
    <GeoServiceLinks serviceLabel={geoLinkLabel} />
  </div>
</ServiceLayout>
