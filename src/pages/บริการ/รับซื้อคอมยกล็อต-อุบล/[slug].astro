---
import { getCollection, render } from 'astro:content';
import ServiceLayout from '../../../layouts/ServiceLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import ModelPageAfterContent from '../../../components/ModelPageAfterContent.astro';
import { SITE } from '../../../config/site';
import { servicePath, servicesIndex } from '../../../config/urls';
import { buildBreadcrumbSchema } from '../../../lib/breadcrumbs';
import { resolveModelPageContext } from '../../../lib/model-pages';

export async function getStaticPaths() {
  const models = await getCollection('modelServices');
  return models
    .filter((entry) => entry.data.parentService === 'b2b-lot-ubon')
    .map((entry) => ({
      params: { slug: entry.data.slug },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, category, modelName, areaServed } = entry.data;

const { quickAnswer, acceptedConditions, rejectedConditions, displayFaqs } =
  resolveModelPageContext(entry.data);

const canonical = `/บริการ/รับซื้อคอมยกล็อต-อุบล/${entry.data.slug}/`;
const ogImage = `${SITE.url}/images/services/b2b-lot-pc.webp`;

const breadcrumbItems = [
  { label: 'หน้าแรก', href: '/' },
  { label: 'บริการรับซื้อ', href: servicesIndex() },
  { label: 'รับซื้อคอมบริษัท/ยกล็อต', href: servicePath('b2b-lot-ubon') },
  { label: modelName },
];

const jsonLd = [
  buildBreadcrumbSchema(breadcrumbItems),
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': `${SITE.url}${canonical}#webpage`,
    url: `${SITE.url}${canonical}`,
    name: title,
    description,
    inLanguage: 'th-TH',
    isPartOf: { '@id': `${SITE.url}/#website` },
    about: { '@id': `${SITE.url}/#localbusiness` },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    '@id': `${SITE.url}${canonical}#service`,
    name: title,
    description,
    provider: { '@id': `${SITE.url}/#localbusiness` },
    areaServed: { '@type': 'AdministrativeArea', name: areaServed },
  },
];
---

<ServiceLayout
  frontmatter={{ title, description, category, faqs: displayFaqs }}
  canonical={canonical}
  ogImage={ogImage}
  featuredImage="/images/services/pc-gaming-ubon.webp"
  jsonLd={jsonLd}
  quickAnswer={quickAnswer}
>
  <div class="not-prose mb-8">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <div class="prose prose-lg mx-auto max-w-none">
    <Content />
  </div>

  <ModelPageAfterContent
    slot="after-content"
    accepted={acceptedConditions}
    rejected={rejectedConditions}
    parentHref={servicePath('b2b-lot-ubon')}
    parentLabel="หน้าหลักบริการรับซื้อคอมบริษัท/ยกล็อต"
    extraLinks={[
      { href: servicePath('pc-corporate-ubon'), label: 'รับซื้อคอมบริษัท อุบล' },
    ]}
  />
</ServiceLayout>
