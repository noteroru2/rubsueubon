---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import HomeIntroSection from '../components/HomeIntroSection.astro';
import HowItWorks from '../components/HowItWorks.astro';
import ServicesSection from '../components/ServicesSection.astro';
import HomePrepareSection from '../components/HomePrepareSection.astro';
import PopularProductsSection from '../components/PopularProductsSection.astro';
import AreasSection from '../components/AreasSection.astro';
import RealWorkSection from '../components/RealWorkSection.astro';
import BlogRecommendSection from '../components/BlogRecommendSection.astro';
import HomeServiceAreasSection from '../components/HomeServiceAreasSection.astro';
import HomeWhyLineSection from '../components/HomeWhyLineSection.astro';
import FAQSection from '../components/FAQSection.astro';
import ContactSection from '../components/ContactSection.astro';
import ServiceClustersSection from '../components/ServiceClustersSection.astro';
import { getCollection } from 'astro:content';
import { districts } from '../lib/districts';
import {
  buildLocalBusinessSchema,
  buildFAQPageSchema,
  buildWebSiteSchema,
  buildOrganizationSchema,
  homepageFAQs,
} from '../lib/schema';

const services = await getCollection('services');
const allUpdates = (await getCollection('updates')).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
const allBlogs = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const pageTitle = 'รับซื้อสินค้าไอที อุบลราชธานี | รับซื้ออุบล.com';
const pageDescription =
  'รับซื้อโทรศัพท์มือถือ โน้ตบุ๊ก กล้อง และอุปกรณ์ไอทีมือหนึ่ง-มือสองในอุบลราชธานี ส่งรูปประเมินราคาก่อนได้ ฟรีผ่าน LINE @buyhub จ่ายเงินสดทันที';

const jsonLd = [
  buildWebSiteSchema(),
  buildLocalBusinessSchema(),
  buildOrganizationSchema(),
  buildFAQPageSchema(homepageFAQs),
];
---

<BaseLayout title={pageTitle} description={pageDescription} jsonLd={jsonLd} showMobileCTA>
  <Hero />
  <HomeIntroSection />
  <ServicesSection services={services} />
  <HowItWorks />
  <HomePrepareSection />
  <PopularProductsSection />
  <AreasSection districts={districts.filter((d: any) => d.active)} />
  <RealWorkSection updates={allUpdates} />
  <BlogRecommendSection posts={allBlogs} />
  <HomeServiceAreasSection />
  <HomeWhyLineSection />
  <FAQSection faqs={homepageFAQs} />
  <ContactSection />
  <ServiceClustersSection />
</BaseLayout>
