---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTAButton from '../../components/CTAButton.astro';
import { SITE } from '../../config/site';
import { areaPath, areasIndex, pricingPage, servicePath, updatePath, updatesIndex } from '../../config/urls';
import {
  districts,
  buildDistrictH1,
  buildDistrictPageTitle,
  buildDistrictDescription,
  buildDistrictKeywords,
  buildDistrictFAQs,
} from '../../lib/districts';
import { buildBreadcrumbSchema } from '../../lib/breadcrumbs';
import { buildDistrictLocalBusinessSchema, buildFAQPageSchema } from '../../lib/schema';
import { buildDistrictSections } from '../../lib/district-content';

export function getStaticPaths() {
  return districts.map((district) => ({
    params: { district: district.slug },
    props: { district },
  }));
}

const { district } = Astro.props;
const { id, name, slug, latitude, longitude, review } = district;

const h1 = buildDistrictH1(name);
const pageTitle = buildDistrictPageTitle(name);
const description = buildDistrictDescription(name);
const keywords = buildDistrictKeywords(name);
const faqs = buildDistrictFAQs(name);
const canonical = areaPath(slug);

const mapUrl = `https://www.google.com/maps?q=${latitude},${longitude}`;

const breadcrumbItems = [
  { label: 'หน้าแรก', href: '/' },
  { label: 'พื้นที่ให้บริการ', href: areasIndex() },
  { label: `อำเภอ${name}` },
];

const contentSections = buildDistrictSections(name, id, latitude, longitude);

const districtUpdates = (await getCollection('updates'))
  .filter((u) => u.data.relatedAreaSlug === id)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const serviceLinks = [
  { href: servicePath('smartphone-ubon'), label: 'รับซื้อโทรศัพท์มือถือ', icon: '/images/services/smartphone.svg' },
  { href: servicePath('notebook-ubon'), label: 'รับซื้อโน้ตบุ๊ก', icon: '/images/services/notebook.svg' },
  { href: servicePath('camera-ubon'), label: 'รับซื้อกล้อง', icon: '/images/services/camera.svg' },
  { href: servicePath('trade-in-ubon'), label: 'รับเทิร์นสินค้าไอที', icon: '/images/services/smartphone.svg' },
];

const jsonLd = [
  buildBreadcrumbSchema(breadcrumbItems),
  buildDistrictLocalBusinessSchema(district),
  buildFAQPageSchema(faqs),
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': `${SITE.url}${canonical}#webpage`,
    url: `${SITE.url}${canonical}`,
    name: h1,
    description,
    inLanguage: 'th-TH',
    isPartOf: { '@id': `${SITE.url}/#website` },
    about: { '@id': `${SITE.url}${canonical}#localbusiness` },
  },
];
---

<BaseLayout
  title={pageTitle}
  description={description}
  canonical={canonical}
  keywords={keywords}
  jsonLd={jsonLd}
  showMobileCTA
>
  <section class="relative overflow-hidden bg-gradient-to-br from-brand via-brand-dark to-ink text-white">
    <div class="pointer-events-none absolute inset-0 opacity-20" aria-hidden="true">
      <div class="absolute -right-20 -top-20 h-72 w-72 rounded-full bg-white/20 blur-3xl"></div>
      <div class="absolute -bottom-24 -left-16 h-64 w-64 rounded-full bg-line/30 blur-3xl"></div>
    </div>

    <div class="relative mx-auto max-w-6xl px-4 py-14 sm:px-6 sm:py-20">
      <div class="mb-6 text-white/70 [&_a]:text-white/80 [&_a:hover]:text-white [&_span]:text-white">
        <Breadcrumbs items={breadcrumbItems} />
      </div>

      <div class="max-w-3xl">
        <p class="inline-flex items-center rounded-full bg-white/10 px-3 py-1 text-sm font-medium ring-1 ring-white/20">
          อำเภอ{name} · อุบลราชธานี
        </p>
        <h1 class="mt-5 text-2xl font-extrabold leading-tight tracking-tight sm:text-3xl lg:text-4xl">
          {h1}
        </h1>
        <p class="mt-5 text-base leading-relaxed text-white/85 sm:text-lg">{description}</p>
        <div class="mt-8">
          <CTAButton label="ประเมินราคาฟรีทันที" class="w-full sm:w-auto" />
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-line py-10 sm:py-12">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="grid gap-8 lg:grid-cols-2">
        <div>
          <h2 class="text-xl font-bold text-ink">พื้นที่ให้บริการ อำเภอ{name}</h2>
          <p class="mt-3 text-sm leading-relaxed text-muted">
            เราให้บริการรับซื้อและรับเทิร์นสินค้าไอทีในอำเภอ{name} อุบลราชธานี สามารถนัดรับสินค้าถึงที่หรือตกลงจุดนัดพบที่สะดวก
            ประเมินราคาฟรีผ่าน LINE @buyhub ก่อนนัดรับเพื่อความรวดเร็วและโปร่งใส
          </p>
          <a
            href={mapUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-brand hover:underline"
          >
            ดูแผนที่อำเภอ{name} บน Google Maps →
          </a>
        </div>

        {
          review && (
            <blockquote class="rounded-2xl border border-line bg-brand/5 p-6">
              <div class="flex gap-0.5 text-amber-400" aria-hidden="true">
                <>
                  <span>★</span>
                  <span>★</span>
                  <span>★</span>
                  <span>★</span>
                  <span>★</span>
                </>
              </div>
              <p class="mt-3 text-sm leading-relaxed text-ink">"{review.text}"</p>
              <footer class="mt-4 text-sm">
                <cite class="not-italic font-semibold">{review.author}</cite>
                <span class="text-muted"> — {review.location}</span>
              </footer>
            </blockquote>
          )
        }
      </div>
    </div>
  </section>

  <section class="py-14 sm:py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <div class="not-prose mb-10 grid grid-cols-3 gap-3 sm:grid-cols-3">
        <figure class="m-0 overflow-hidden rounded-xl shadow-sm">
          <img
            src="/images/services/smartphone-iphone-android.webp"
            alt={`รับซื้อโทรศัพท์มือถือ iPhone Samsung อำเภอ${name}`}
            width="320"
            height="213"
            loading="lazy"
            decoding="async"
            class="h-28 w-full object-cover sm:h-36"
          />
          <figcaption class="bg-surface px-2 py-1 text-center text-xs text-muted">รับซื้อโทรศัพท์มือถือ</figcaption>
        </figure>
        <figure class="m-0 overflow-hidden rounded-xl shadow-sm">
          <img
            src="/images/services/notebook-ubon.webp"
            alt={`รับซื้อโน้ตบุ๊ก MacBook อำเภอ${name}`}
            width="320"
            height="213"
            loading="lazy"
            decoding="async"
            class="h-28 w-full object-cover sm:h-36"
          />
          <figcaption class="bg-surface px-2 py-1 text-center text-xs text-muted">รับซื้อโน้ตบุ๊ก</figcaption>
        </figure>
        <figure class="m-0 overflow-hidden rounded-xl shadow-sm">
          <img
            src="/images/services/camera-sony-canon-fujifilm.webp"
            alt={`รับซื้อกล้อง Sony Canon อำเภอ${name}`}
            width="320"
            height="213"
            loading="lazy"
            decoding="async"
            class="h-28 w-full object-cover sm:h-36"
          />
          <figcaption class="bg-surface px-2 py-1 text-center text-xs text-muted">รับซื้อกล้อง</figcaption>
        </figure>
      </div>

      <article
        class="prose prose-lg max-w-none prose-headings:text-ink prose-p:text-muted prose-a:text-brand prose-li:text-muted"
      >
        {
          contentSections.map((section, i) => (
            <>
              <h2>{section.heading}</h2>
              <div set:html={section.htmlContent} class="space-y-4" />
              {i === 2 && (
                <figure class="not-prose my-8 overflow-hidden rounded-xl shadow-sm">
                  <img
                    src="/images/cash-3d.webp"
                    alt={`รับเงินสดทันทีขายไอที อำเภอ${name}`}
                    width="800"
                    height="450"
                    loading="lazy"
                    decoding="async"
                    class="w-full object-cover"
                  />
                </figure>
              )}
              {i === 5 && (
                <figure class="not-prose my-8 overflow-hidden rounded-xl shadow-sm">
                  <img
                    src="/images/services/apple-devices-macbook-imac.webp"
                    alt={`รับซื้อ Apple MacBook iPad อำเภอ${name}`}
                    width="800"
                    height="450"
                    loading="lazy"
                    decoding="async"
                    class="w-full object-cover"
                  />
                </figure>
              )}
            </>
          ))
        }
        <p>
          ดูบริการเฉพาะทาง:{' '}
          <a href={servicePath('smartphone-ubon')}>รับซื้อโทรศัพท์มือถือ</a>,{' '}
          <a href={servicePath('notebook-ubon')}>รับซื้อโน้ตบุ๊ก</a>,{' '}
          <a href={servicePath('camera-ubon')}>รับซื้อกล้อง</a>,{' '}
          <a href={servicePath('trade-in-ubon')}>รับเทิร์นไอที</a>
        </p>
      </article>
    </div>
  </section>

  <section class="bg-surface-alt py-14 sm:py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <h2 class="text-xl font-bold text-ink sm:text-2xl">บริการรับซื้อ-รับเทิร์นในอำเภอ{name}</h2>
      <p class="mt-3 max-w-2xl text-muted">
        เลือกประเภทสินค้าที่ต้องการขายหรือเทิร์นในอำเภอ{name}
      </p>

      <ul class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          serviceLinks.map((service) => (
            <li>
              <a
                href={service.href}
                class="group flex h-full items-center gap-4 rounded-2xl border border-line bg-surface p-4 shadow-sm transition hover:border-brand/30 hover:shadow-md"
              >
                <img
                  src={service.icon}
                  alt={`ไอคอน${service.label}`}
                  width="48"
                  height="48"
                  loading="lazy"
                  decoding="async"
                  class="h-12 w-12 shrink-0"
                />
                <span class="font-semibold text-ink group-hover:text-brand">{service.label}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="py-14 sm:py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <h2 class="text-xl font-bold text-ink sm:text-2xl">ขายไอทีในอำเภอ{name} ง่ายๆ 3 ขั้นตอน</h2>
      <ol class="mt-8 grid gap-4 sm:grid-cols-3">
        <li class="rounded-2xl border border-line bg-surface p-5">
          <span
            class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-brand/10 text-sm font-bold text-brand"
            >1</span
          >
          <h3 class="mt-3 font-bold text-ink">แอด LINE @buyhub</h3>
          <p class="mt-2 text-sm text-muted">เพิ่มเพื่อน LINE OA เพื่อเริ่มแชทและประเมินราคาทันที</p>
        </li>
        <li class="rounded-2xl border border-line bg-surface p-5">
          <span
            class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-brand/10 text-sm font-bold text-brand"
            >2</span
          >
          <h3 class="mt-3 font-bold text-ink">ส่งรูปประเมินราคา</h3>
          <p class="mt-2 text-sm text-muted">ถ่ายรูปสินค้า แจ้งรุ่นและสภาพ รับใบเสนอราคาภายในไม่กี่นาที</p>
        </li>
        <li class="rounded-2xl border border-line bg-surface p-5">
          <span
            class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-brand/10 text-sm font-bold text-brand"
            >3</span
          >
          <h3 class="mt-3 font-bold text-ink">นัดรับ-จ่ายเงินสด</h3>
          <p class="mt-2 text-sm text-muted">ตกลงราคาแล้วนัดรับในอำเภอ{name} จ่ายเงินสดทันที ไม่มีค่าแอบแฝง</p>
        </li>
      </ol>
    </div>
  </section>

  {
    districtUpdates.length > 0 && (
      <section class="bg-surface-alt py-14 sm:py-16">
        <div class="mx-auto max-w-6xl px-4 sm:px-6">
          <h2 class="text-xl font-bold text-ink sm:text-2xl">ผลงานรับซื้อในอำเภอ{name}</h2>
          <p class="mt-2 text-muted">เคสจริงจากลูกค้าในอำเภอ{name} — ราคาโปร่งใส จ่ายเงินสดทันที</p>
          <ul class="mt-6 grid gap-4 sm:grid-cols-3">
            {districtUpdates.map((post) => (
              <li>
                <a
                  href={updatePath(post.data.slug)}
                  class="block h-full rounded-2xl border border-line bg-surface p-5 transition hover:border-brand/30 hover:shadow-md"
                >
                  <p class="font-semibold text-ink hover:text-brand">{post.data.title}</p>
                  <p class="mt-2 text-sm text-muted line-clamp-2">{post.data.description}</p>
                </a>
              </li>
            ))}
          </ul>
          <p class="mt-4 text-sm">
            <a href={updatesIndex()} class="font-semibold text-brand hover:underline">
              ดูผลงานทั้งหมด →
            </a>
            {' · '}
            <a href={pricingPage()} class="font-semibold text-brand hover:underline">
              วิธีประเมินราคา →
            </a>
          </p>
        </div>
      </section>
    )
  }

  <section class="py-14 sm:py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <h2 class="text-xl font-bold text-ink sm:text-2xl">คำถามที่พบบ่อย — อำเภอ{name}</h2>
      <div class="mt-6 space-y-3">
        {
          faqs.map((faq) => (
            <details class="group rounded-2xl border border-line bg-surface open:border-brand/30">
              <summary class="cursor-pointer list-none px-5 py-4 font-semibold text-ink marker:content-none [&::-webkit-details-marker]:hidden">
                <span class="flex items-center justify-between gap-4">
                  {faq.question}
                  <span class="shrink-0 text-brand transition group-open:rotate-180" aria-hidden="true">
                    ▼
                  </span>
                </span>
              </summary>
              <div class="border-t border-line px-5 py-4 text-sm leading-relaxed text-muted">{faq.answer}</div>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <section class="py-14 sm:py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <h2 class="text-lg font-bold text-ink">พื้นที่ให้บริการอื่นในอุบลราชธานี</h2>
      <ul class="mt-4 flex flex-wrap gap-2">
        {
          districts
            .filter((d) => d.slug !== slug)
            .map((d) => (
              <li>
                <a
                  href={areaPath(d.slug)}
                  class="inline-block rounded-full border border-line bg-surface px-4 py-2 text-sm font-medium text-muted transition hover:border-brand/30 hover:text-brand"
                >
                  อำเภอ{d.name}
                </a>
              </li>
            ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
