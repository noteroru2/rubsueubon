---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTAButton from '../../components/CTAButton.astro';
import { SITE } from '../../config/site';
import { areaPath, areasIndex, pricingPage, servicePath, updatePath, updatesIndex } from '../../config/urls';
import { buildBreadcrumbSchema } from '../../lib/breadcrumbs';

export async function getStaticPaths() {
  const areas = await getCollection('areas');
  return areas.map((area) => ({
    params: { district: area.data.slug },
    props: { area },
  }));
}

const { area } = Astro.props;
const { Content } = await render(area);
const { data } = area;
const {
  title: pageTitle,
  description,
  heroTitle,
  heroSubtitle,
  areaName,
  slug,
  keywords,
} = data;

const h1 = heroTitle;
const canonical = areaPath(slug);

const breadcrumbItems = [
  { label: 'หน้าแรก', href: '/' },
  { label: 'พื้นที่ให้บริการ', href: areasIndex() },
  { label: areaName },
];

const districtUpdates = (await getCollection('updates'))
  .filter((u) => u.data.relatedAreaSlug === slug)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const serviceLinks = [
  { href: servicePath('smartphone-ubon'), label: 'รับซื้อโทรศัพท์มือถือ', icon: '/images/services/smartphone.svg' },
  { href: servicePath('notebook-ubon'), label: 'รับซื้อโน้ตบุ๊ก', icon: '/images/services/notebook.svg' },
  { href: servicePath('camera-ubon'), label: 'รับซื้อกล้อง', icon: '/images/services/camera.svg' },
  { href: servicePath('trade-in-ubon'), label: 'รับเทิร์นสินค้าไอที', icon: '/images/services/smartphone.svg' },
];

const jsonLd = [
  buildBreadcrumbSchema(breadcrumbItems),
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': `${SITE.url}${canonical}#webpage`,
    url: `${SITE.url}${canonical}`,
    name: h1,
    description,
    inLanguage: 'th-TH',
    isPartOf: { '@id': `${SITE.url}/#website` },
  },
];
---
<BaseLayout
  title={pageTitle}
  description={description}
  canonical={canonical}
  keywords={keywords}
  jsonLd={jsonLd}
  showMobileCTA
>
  <section class="relative overflow-hidden bg-gradient-to-br from-brand via-brand-dark to-ink text-white">
    <div class="pointer-events-none absolute inset-0 opacity-20" aria-hidden="true">
      <div class="absolute -right-20 -top-20 h-72 w-72 rounded-full bg-white/20 blur-3xl"></div>
      <div class="absolute -bottom-24 -left-16 h-64 w-64 rounded-full bg-line/30 blur-3xl"></div>
    </div>

    <div class="relative mx-auto max-w-6xl px-4 py-14 sm:px-6 sm:py-20">
      <div class="mb-6 text-white/70 [&_a]:text-white/80 [&_a:hover]:text-white [&_span]:text-white">
        <Breadcrumbs items={breadcrumbItems} />
      </div>

      <div class="max-w-3xl">
        <p class="inline-flex items-center rounded-full bg-white/10 px-3 py-1 text-sm font-medium ring-1 ring-white/20">
          {areaName} · อุบลราชธานี
        </p>
        <h1 class="mt-5 text-2xl font-extrabold leading-tight tracking-tight sm:text-3xl lg:text-4xl">
          {h1}
        </h1>
        <p class="mt-5 text-base leading-relaxed text-white/85 sm:text-lg">{heroSubtitle}</p>
        <div class="mt-8">
          <CTAButton label="ประเมินราคาฟรีทันที" class="w-full sm:w-auto" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-14 sm:py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <article
        class="prose prose-lg max-w-none prose-headings:text-ink prose-p:text-muted prose-a:text-brand prose-li:text-muted"
      >
        <Content />
      </article>
    </div>
  </section>

  <section class="bg-surface-alt py-14 sm:py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <h2 class="text-xl font-bold text-ink sm:text-2xl">บริการรับซื้อ-รับเทิร์นใน{areaName}</h2>
      <p class="mt-3 max-w-2xl text-muted">
        เลือกประเภทสินค้าที่ต้องการขายหรือเทิร์น
      </p>

      <ul class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          serviceLinks.map((service) => (
            <li>
              <a
                href={service.href}
                class="group flex h-full items-center gap-4 rounded-2xl border border-line bg-surface p-4 shadow-sm transition hover:border-brand/30 hover:shadow-md"
              >
                <img
                  src={service.icon}
                  alt={`ไอคอน${service.label}`}
                  width="48"
                  height="48"
                  loading="lazy"
                  decoding="async"
                  class="h-12 w-12 shrink-0"
                />
                <span class="font-semibold text-ink group-hover:text-brand">{service.label}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</BaseLayout>
