---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';
import { areasIndex, servicesIndex, updatePath, updatesIndex } from '../../config/urls';
import { buildBreadcrumbSchema } from '../../lib/breadcrumbs';

const allUpdates = (await getCollection('updates')).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const pageTitle = 'ผลงานรับซื้อล่าสุด | รับซื้ออุบล.com';
const pageDescription = 'อัปเดตผลงานรับซื้อ-รับเทิร์นไอทีล่าสุดในอุบลราชธานี รูปจริง ราคาจริง สร้างความน่าเชื่อถือ';

const breadcrumbItems = [{ label: 'หน้าแรก', href: '/' }, { label: 'ผลงานรับซื้อล่าสุด' }];

const jsonLd = [buildBreadcrumbSchema(breadcrumbItems)];

function formatDate(date: Date): string {
  return date.toLocaleDateString('th-TH', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title={pageTitle} description={pageDescription} jsonLd={jsonLd}>
  <div class="py-12 sm:py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <Breadcrumbs items={breadcrumbItems} />
      <h1 class="mt-6 text-2xl font-extrabold text-ink sm:text-3xl">ผลงานรับซื้อล่าสุด</h1>
      <p class="mt-3 text-muted">{pageDescription}</p>

      <div class="prose prose-lg mt-8 max-w-none prose-p:text-muted prose-a:text-brand prose-headings:text-ink">
        <p>
          หน้านี้รวบรวมเคสรับซื้อ-รับเทิร์นจริงในอุบลราชธานี เพื่อให้ลูกค้าใหม่เห็นขั้นตอนการทำงาน ราคาที่โปร่งใส
          และพื้นที่ที่เราให้บริการ ทุกเคสเริ่มจากการส่งรูปมาที่ LINE <strong>@buyhub</strong>
          ประเมินราคาฟรี แล้วนัดรับจ่ายเงินสดทันที
        </p>
        <p>
          หากคุณสนใจขายสินค้าเดียวกัน ดูรายละเอียดบริการที่ <a href={servicesIndex()}>หน้าบริการรับซื้อ</a>
          หรือเลือก <a href={areasIndex()}>พื้นที่ให้บริการ</a> ตามอำเภอของคุณ
        </p>
      </div>

      <ul class="mt-10 space-y-6">
        {
          allUpdates.map((post) => (
            <li class="rounded-2xl border border-line bg-surface p-6 shadow-sm transition hover:border-brand/30">
              <time datetime={post.data.pubDate.toISOString()} class="text-xs font-medium text-brand">
                {formatDate(post.data.pubDate)}
              </time>
              <h2 class="mt-2 text-lg font-bold text-ink">
                <a href={updatePath(post.data.slug)} class="hover:text-brand">
                  {post.data.title}
                </a>
              </h2>
              <p class="mt-2 text-sm text-muted">{post.data.description}</p>
              <a
                href={updatePath(post.data.slug)}
                class="mt-3 inline-block text-sm font-semibold text-brand hover:underline"
              >
                อ่านต่อ →
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</BaseLayout>
