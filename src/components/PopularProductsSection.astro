---
import { popularProducts } from '../config/home-hub';
---

<section id="popular-products" class="bg-surface-alt py-14 sm:py-16">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-2xl font-bold text-ink sm:text-3xl">สินค้าที่รับซื้อบ่อยในอุบล</h2>
      <p class="mt-3 text-muted">รุ่นยอดนิยมที่ลูกค้ามักส่งรูปมาประเมินราคา — เลือกสินค้าใกล้เคียงแล้วดูรายละเอียด</p>
    </div>

    <ul class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        popularProducts.map((item) => (
          <li>
            <a
              href={item.href}
              class="group flex items-center gap-4 rounded-2xl border border-line bg-surface p-4 shadow-sm transition hover:border-brand/30 hover:shadow-md"
            >
              <div class="flex h-14 w-14 shrink-0 items-center justify-center overflow-hidden rounded-xl bg-brand/5">
                <img
                  src={item.image}
                  alt=""
                  width="56"
                  height="56"
                  loading="lazy"
                  decoding="async"
                  class="h-full w-full object-cover"
                />
              </div>
              <span class="font-semibold text-ink group-hover:text-brand">{item.label}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
