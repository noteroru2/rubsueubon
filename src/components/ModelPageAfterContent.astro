---
import ConditionsScope from './ConditionsScope.astro';

export interface Props {
  accepted: string[];
  rejected: string[];
  parentHref: string;
  parentLabel: string;
  extraLinks?: { href: string; label: string }[];
}

const { accepted, rejected, parentHref, parentLabel, extraLinks = [] } = Astro.props;
---

<ConditionsScope accepted={accepted} rejected={rejected} />

<div class="border-t border-line py-12 sm:py-14">
  <div class="mx-auto max-w-3xl px-4 sm:px-6">
    <div class="rounded-2xl border border-line bg-surface p-6 shadow-sm">
      <h3 class="text-lg font-bold text-ink">ลิงก์ข้อมูลเพิ่มเติม</h3>
      <ul class="mt-4 space-y-2 text-sm text-brand">
        <li>
          👉 <a href={parentHref} class="hover:underline">{parentLabel}</a>
        </li>
        {
          extraLinks.map((link) => (
            <li>
              👉 <a href={link.href} class="hover:underline">{link.label}</a>
            </li>
          ))
        }
        <li>👉 <a href="/บริการ/" class="hover:underline">บริการรับซื้อสินค้าไอทีทั้งหมด</a></li>
        <li>👉 <a href="/พื้นที่/" class="hover:underline">พื้นที่ให้บริการในอุบลราชธานี</a></li>
      </ul>
    </div>
  </div>
</div>
