---
const testimonials = [
  {
    name: 'คุณก้อง',
    location: 'เมืองอุบลราชธานี',
    text: 'ขาย iPhone มือสองได้ราคาดีกว่าร้านอื่น ตอบไวมาก จ่ายเงินสดทันทีเลย ประทับใจครับ',
    rating: 5,
  },
  {
    name: 'คุณมิ้นท์',
    location: 'วารินชำราบ',
    text: 'เทิร์นโน้ตบุ๊กเก่าแล้วได้เงินก้อน ใช้ต่อซื้อเครื่องใหม่ สะดวกมาก ไม่ต้องโพสต์ขายเอง',
    rating: 5,
  },
  {
    name: 'คุณต้น',
    location: 'อุบลราชธานี',
    text: 'ขายกล้อง Mirrorless ผ่าน LINE ส่งรูปไป ได้ราคาชัดเจน ไม่มีกดราคาทีหลัง แนะนำเลย',
    rating: 5,
  },
];

const guarantees = [
  {
    title: 'รับประกันราคายุติธรรม',
    description: 'ประเมินตามสภาพจริงและราคาตลาดในอุบลราชธานี ไม่กดราคาหลังนัดรับ',
  },
  {
    title: 'โปร่งใส ไม่มีค่าแอบแฝง',
    description: 'แจ้งราคาชัดเจนก่อนตกลง ไม่มีค่าธรรมเนียมที่ซ่อนเร้น',
  },
  {
    title: 'จ่ายเงินทันที',
    description: 'เมื่อตกลงราคาแล้ว รับเงินสดทันที ไม่ต้องรอนาน',
  },
];
---

<section class="py-16 sm:py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-2xl font-bold text-ink sm:text-3xl">ลูกค้าไว้วางใจ รับซื้ออุบล.com</h2>
      <p class="mt-3 text-muted">รีวิวจริงจากผู้ขายในอุบลราชธานีและพื้นที่ใกล้เคียง</p>
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-3">
      {
        guarantees.map((item) => (
          <div class="rounded-2xl border border-line bg-brand/5 p-5">
            <h3 class="font-bold text-brand">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{item.description}</p>
          </div>
        ))
      }
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-3">
      {
        testimonials.map((item) => (
          <blockquote class="rounded-2xl border border-line bg-surface p-6 shadow-sm">
            <div class="flex gap-0.5 text-amber-400" aria-label={`คะแนน ${item.rating} จาก 5`}>
              {Array.from({ length: item.rating }).map(() => (
                <span aria-hidden="true">★</span>
              ))}
            </div>
            <p class="mt-3 text-sm leading-relaxed text-ink">"{item.text}"</p>
            <footer class="mt-4 text-sm">
              <cite class="not-italic font-semibold text-ink">{item.name}</cite>
              <span class="text-muted"> — {item.location}</span>
            </footer>
          </blockquote>
        ))
      }
    </div>
  </div>
</section>
