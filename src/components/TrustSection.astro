---
const testimonials = [
  {
    name: 'ลูกค้าในอุบลราชธานี',
    location: 'ตัวเมือง',
    text: 'เพราะเราประเมินตามสภาพจริงและราคาตลาดปัจจุบัน ไม่กดราคา ทำให้ได้ราคาที่สะท้อนคุณภาพสินค้ามากที่สุด',
    rating: 5,
    image: '',
  },
  {
    name: 'ลูกค้าในวารินชำราบ',
    location: 'ย่านมหาวิทยาลัย',
    text: 'การประเมินราคาที่โปร่งใส แจ้งเหตุผลและราคาอย่างชัดเจนก่อนตัดสินใจ ทำให้ได้รับความไว้วางใจในการใช้บริการ',
    rating: 5,
    image: '',
  },
  {
    name: 'ลูกค้าโซนอำเภอรอบนอก',
    location: 'เดชอุดม และอื่นๆ',
    text: 'มีบริการส่งรูปประเมินราคาผ่าน LINE ก่อน ทำให้ทราบราคาเบื้องต้นได้ทันที ไม่ต้องเสียเวลาเดินทางไกลหากราคายังไม่ตรงใจ',
    rating: 5,
    image: '',
  },
];

const guarantees = [
  {
    title: 'รับประกันราคายุติธรรม',
    description: 'ประเมินตามสภาพจริงและราคาตลาดในอุบลราชธานี ไม่กดราคาหลังนัดรับ',
  },
  {
    title: 'โปร่งใส ไม่มีค่าแอบแฝง',
    description: 'แจ้งราคาชัดเจนก่อนตกลง ไม่มีค่าธรรมเนียมที่ซ่อนเร้น',
  },
  {
    title: 'จ่ายเงินทันที',
    description: 'เมื่อตกลงราคาแล้ว รับเงินสดทันที ไม่ต้องรอนาน',
  },
];
---

<section class="py-16 sm:py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-2xl font-bold text-ink sm:text-3xl">ลูกค้าไว้วางใจ รับซื้ออุบล.com</h2>
      <p class="mt-3 text-muted">เหตุผลที่ลูกค้ามักสอบถามราคากับเรา</p>
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-3">
      {
        guarantees.map((item) => (
          <div class="rounded-2xl border border-line bg-brand/5 p-5">
            <h3 class="font-bold text-brand">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink/80">{item.description}</p>
          </div>
        ))
      }
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-3">
      {
        testimonials.map((item) => (
          <blockquote class="flex flex-col overflow-hidden rounded-2xl border border-line bg-surface shadow-sm">
            {item.image && (
              <img
                src={item.image}
                alt={`รีวิวรับซื้อจาก${item.name}`}
                loading="lazy"
                decoding="async"
                class="h-48 w-full object-cover"
              />
            )}
            <div class="flex flex-1 flex-col p-6">
              <div role="img" aria-label={`คะแนน ${item.rating} จาก 5`} class="flex gap-0.5 text-amber-400">
                {Array.from({ length: item.rating }).map(() => (
                  <span aria-hidden="true">★</span>
                ))}
              </div>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-ink">"{item.text}"</p>
            </div>
          </blockquote>
        ))
      }
    </div>
  </div>
</section>
