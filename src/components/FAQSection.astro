---
import CTAButton from './CTAButton.astro';

interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  faqs: FAQItem[];
  title?: string;
  subtitle?: string;
}

const { faqs, title = 'คำถามที่พบบ่อย', subtitle = 'คำตอบสำหรับคนที่ค้นหา "ร้านรับเทิร์นไอที อุบล"' } = Astro.props;
---

<section id="faq" class="py-16 sm:py-20">
  <div class="mx-auto max-w-3xl px-4 sm:px-6">
    <div class="text-center">
      <h2 class="text-2xl font-bold text-ink sm:text-3xl">{title}</h2>
      <p class="mt-3 text-muted">{subtitle}</p>
    </div>

    <div class="mt-10 space-y-3">
      {
        faqs.map((faq) => (
          <details class="group rounded-2xl border border-line bg-surface open:border-brand/30 open:shadow-sm">
            <summary class="cursor-pointer list-none px-5 py-4 font-semibold text-ink marker:content-none [&::-webkit-details-marker]:hidden">
              <span class="flex items-center justify-between gap-4">
                {faq.question}
                <span class="shrink-0 text-brand transition group-open:rotate-180" aria-hidden="true">
                  ▼
                </span>
              </span>
            </summary>
            <div class="border-t border-line px-5 py-4 text-sm leading-relaxed text-muted">{faq.answer}</div>
          </details>
        ))
      }
    </div>

    <div class="mt-10 rounded-2xl bg-gradient-to-r from-brand to-brand-dark p-8 text-center text-white">
      <h3 class="text-xl font-bold">พร้อมขายไอทีแล้ว?</h3>
      <p class="mt-2 text-white/85">ส่งรูปมาประเมินราคาฟรีทันที ไม่มีข้อผูกมัด</p>
      <div class="mt-5">
        <CTAButton label="แชท LINE @buyhub" />
      </div>
    </div>
  </div>
</section>
