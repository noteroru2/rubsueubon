---
import CTAButton from './CTAButton.astro';
import { getLineOALink } from '../config/site';

const lineLink = getLineOALink();
---

<section class="relative overflow-hidden bg-[#0a0a0a] text-white">
  <div class="absolute inset-0 z-0">
    <img
      src="/images/hero/home-hero-buy-it-ubon.webp"
      alt="รับซื้อไอที อุบลราชธานี มือถือ โน้ตบุ๊ค กล้อง แท็บเล็ตมือสอง ประเมินราคาฟรี จ่ายเงินทันที"
      width="1600"
      height="900"
      fetchpriority="high"
      decoding="async"
      class="h-full w-full object-cover object-right"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-[#0a0a0a] via-[#0a0a0a]/80 to-transparent sm:via-[#0a0a0a]/50">
    </div>
    <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a] via-transparent to-transparent sm:hidden"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-24 lg:py-28">
    <div class="max-w-2xl">
      <p class="inline-flex items-center rounded-full bg-white/10 px-3 py-1 text-sm font-medium ring-1 ring-white/20">
        รับซื้อ-รับเทิร์นไอที อุบลราชธานี
      </p>
      <h1 class="mt-5 text-3xl font-extrabold leading-tight tracking-tight sm:text-4xl lg:text-[2.75rem]">
        รับซื้อสินค้าไอที อุบลราชธานี ส่งรูปประเมินราคาก่อนได้
      </h1>
      <p class="mt-5 text-base leading-relaxed text-white/85 sm:text-lg">
        รับพิจารณา iPhone, iPad, MacBook, โน๊ตบุ๊ค, คอมพิวเตอร์, กล้อง, เครื่องเกม และสินค้าไอทีหลายประเภทในอุบลราชธานี ราคาขึ้นอยู่กับรุ่น สภาพ อุปกรณ์ และราคาตลาดช่วงนั้น
      </p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
        <CTAButton href={lineLink} label="ประเมินราคาฟรีทันที" class="w-full sm:w-auto" />
        <a
          href="#how-it-works"
          class="inline-flex w-full items-center justify-center rounded-full border border-white/30 px-6 py-3.5 text-base font-semibold text-white transition hover:bg-white/10 sm:w-auto"
        >
          ดูขั้นตอนการขาย
        </a>
      </div>

      <ul class="mt-8 flex flex-wrap gap-x-6 gap-y-2 text-sm text-white/75" aria-label="จุดเด่น">
        <li class="flex items-center gap-2">
          <span class="text-line-light" aria-hidden="true">✓</span> ประเมินฟรี ไม่มีค่าใช้จ่าย
        </li>
        <li class="flex items-center gap-2">
          <span class="text-line-light" aria-hidden="true">✓</span> จ่ายเงินสดทันที
        </li>
        <li class="flex items-center gap-2">
          <span class="text-line-light" aria-hidden="true">✓</span> ราคายุติธรรม
        </li>
      </ul>
    </div>
  </div>
</section>
