---
import type { District } from '../lib/districts';
import { areaPath } from '../config/urls';

interface Props {
  districts: District[];
}

const { districts } = Astro.props;
---

<section id="areas" class="py-16 sm:py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-2xl font-bold text-ink sm:text-3xl">พื้นที่ให้บริการทั่วอุบลราชธานี</h2>
      <p class="mt-3 text-muted">รับซื้อ-รับเทิร์นไอทีครอบคลุมอำเภอหลัก นัดรับถึงที่ จ่ายเงินสดทันที</p>
    </div>

    <ul class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        districts.map((district) => (
          <li class={district.id === 'mueang-ubon' ? 'sm:col-span-2 lg:col-span-1' : ''}>
            {district.active ? (
              <a
                href={areaPath(district.slug)}
                class="group flex items-center justify-between rounded-2xl border border-line bg-surface px-5 py-4 shadow-sm transition hover:border-brand/30 hover:bg-brand/5 hover:shadow-md"
              >
                <span>
                  <span class="block font-bold text-ink group-hover:text-brand">อำเภอ{district.name}</span>
                  <span class="mt-0.5 block text-sm text-muted">รับซื้อโน้ตบุ๊ก มือถือ ไอที</span>
                </span>
                <span class="shrink-0 text-brand transition group-hover:translate-x-0.5" aria-hidden="true">
                  →
                </span>
              </a>
            ) : (
              <div class="flex items-center justify-between rounded-2xl border border-line/50 bg-surface/50 px-5 py-4 opacity-60">
                <span>
                  <span class="block font-bold text-ink">อำเภอ{district.name}</span>
                  <span class="mt-0.5 block text-sm text-muted">กำลังเตรียมเนื้อหาเพิ่มเติม</span>
                </span>
              </div>
            )}
          </li>
        ))
      }
    </ul>

    <p class="mt-6 text-center text-sm text-muted">
      อยู่อำเภออื่นในอุบลราชธานี?
      <a href="https://line.me/R/ti/p/@buyhub" class="font-semibold text-brand hover:underline"> แชท LINE @buyhub </a>
      เพื่อสอบถามพื้นที่ให้บริการ
    </p>
  </div>
</section>
