---
import type { CollectionEntry } from 'astro:content';
import { updatePath, updatesIndex } from '../config/urls';
import { softenHomeCopy } from '../lib/home-safe-copy';

interface Props {
  updates: CollectionEntry<'updates'>[];
}

const { updates } = Astro.props;

function formatDate(date: Date): string {
  return date.toLocaleDateString('th-TH', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<section id="real-work" class="py-14 sm:py-16">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-center">
      <div>
        <h2 class="text-2xl font-bold text-ink sm:text-3xl">เคสจริงล่าสุด</h2>
        <p class="mt-2 text-muted">เคสจริงจากลูกค้าในอุบลราชธานี — มีรายละเอียดสินค้า อำเภอ วันที่ และขั้นตอนการรับซื้อ</p>
      </div>
      <a
        href={updatesIndex()}
        class="shrink-0 rounded-full border border-brand px-4 py-2 text-sm font-semibold text-brand transition hover:bg-brand hover:text-white"
      >
        ดูทั้งหมด →
      </a>
    </div>

    {
      updates.length > 0 ? (
        <ul class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {updates.slice(0, 6).map((post) => (
            <li>
              <article class="relative flex h-full flex-col overflow-hidden rounded-2xl border border-line bg-surface p-5 shadow-sm transition hover:border-brand/30 hover:shadow-md">
                <div class="absolute top-0 right-0 rounded-bl-lg bg-brand px-2 py-1 text-xs font-semibold text-white">
                  เคสจริง
                </div>
                <time datetime={post.data.pubDate.toISOString()} class="text-xs font-medium text-brand">
                  {formatDate(post.data.pubDate)}
                </time>
                {post.data.relatedAreaLabel && (
                  <p class="mt-1 text-xs text-muted">อ.{post.data.relatedAreaLabel}</p>
                )}
                <h3 class="mt-3 text-lg font-bold text-ink">
                  <a href={updatePath(post.data.slug)} class="transition hover:text-brand">
                    {post.data.title}
                  </a>
                </h3>
                <p class="mt-2 flex-1 text-sm leading-relaxed text-muted">{softenHomeCopy(post.data.description)}</p>
                <a href={updatePath(post.data.slug)} class="mt-4 text-sm font-semibold text-brand hover:underline">
                  อ่านต่อ →
                </a>
              </article>
            </li>
          ))}
        </ul>
      ) : (
        <p class="mt-8 text-muted">กำลังอัปเดตผลงาน — ติดตามได้เร็วๆ นี้</p>
      )
    }
  </div>
</section>
