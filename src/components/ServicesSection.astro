---
import type { CollectionEntry } from 'astro:content';
import { servicePath } from '../config/urls';

interface Props {
  services: CollectionEntry<'services'>[];
}

const { services } = Astro.props;
const sorted = [...services].sort((a, b) => a.data.order - b.data.order);

const categoryImages: Record<string, string> = {
  smartphone: '/images/services/smartphone-iphone-android.webp',
  notebook: '/images/services/notebook-ubon.webp',
  camera: '/images/services/camera-sony-canon-fujifilm.webp',
};

const imageAltText: Record<string, string> = {
  '/images/services/smartphone-iphone-android.webp':
    'รับซื้อโทรศัพท์ iPhone Android อุบลราชธานี ตรวจเช็คเครื่องโดยมืออาชีพ',
  '/images/services/notebook-ubon.webp': 'รับซื้อโน้ตบุ๊ก อุบลราชธานี ประเมินราคาโน้ตบุ๊กมือสองทุกยี่ห้อ',
  '/images/services/camera-sony-canon-fujifilm.webp':
    'รับซื้อกล้อง Sony Canon Fujifilm อุบลราชธานี กล้องและเลนส์มือสอง',
  '/images/services/pc-gaming-desktop.webp': 'รับซื้อคอมพิวเตอร์ตั้งโต๊ะ PC Gaming อุบลราชธานี ให้ราคาสูง',
  '/images/services/apple-devices-macbook-imac.webp':
    'รับซื้อ MacBook iMac อุปกรณ์ Apple อุบลราชธานี สภาพดี ให้ราคาสูง',
  '/images/services/ipad-tablet.webp': 'รับซื้อ iPad Tablet มือสอง อุบลราชธานี ตรวจเช็คสภาพโดยมืออาชีพ',
  '/images/services/apple-watch-smartwatch.webp': 'รับซื้อ Apple Watch Smart Watch อุบลราชธานี ทุกรุ่น ให้ราคาสูง',
  '/images/services/pc-parts-gpu-cpu.webp': 'รับซื้อการ์ดจอ CPU อะไหล่คอม อุบลราชธานี ให้ราคาตามตลาด',
  '/images/services/game-console-playstation.webp':
    'รับซื้อ PlayStation Nintendo เครื่องเกม อุบลราชธานี จ่ายเงินสดทันที',
  '/images/services/speaker-jbl-marshall.webp':
    'รับซื้อลำโพง JBL Marshall และเครื่องเสียงมือสอง อุบลราชธานี ให้ราคาสูง',
};
---

<section id="services" class="bg-surface-alt py-16 sm:py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-2xl font-bold text-ink sm:text-3xl">บริการรับซื้อ-รับเทิร์นไอที</h2>
      <p class="mt-3 text-muted">เลือกหมวดสินค้าที่ต้องการขาย เรารับซื้อทุกยี่ห้อในอุบลราชธานี</p>
    </div>

    <ul class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        sorted.map((service) => {
          const image = service.data.featuredImage ?? categoryImages[service.data.category] ?? '/favicon.svg';
          const primaryKeyword = service.data.keywords[0] ?? service.data.category;

          return (
            <li>
              <a
                href={servicePath(service.data.slug)}
                class="group flex h-full flex-col overflow-hidden rounded-2xl border border-line bg-surface shadow-sm transition hover:border-brand/30 hover:shadow-md"
              >
                <div class="flex h-40 items-center justify-center bg-gradient-to-br from-brand/5 to-brand/10">
                  <img
                    src={image}
                    alt={imageAltText[image] ?? `${service.data.navLabel} อุบลราชธานี`}
                    width="800"
                    height="450"
                    loading="lazy"
                    decoding="async"
                    class={
                      image.endsWith('.svg')
                        ? 'h-20 w-20 opacity-90 transition group-hover:scale-105'
                        : 'h-full w-full object-cover transition group-hover:scale-105'
                    }
                  />
                </div>
                <div class="flex flex-1 flex-col p-5">
                  <h3 class="text-lg font-bold text-ink group-hover:text-brand">{service.data.title}</h3>
                  <p class="mt-2 flex-1 text-sm leading-relaxed text-muted">{service.data.description}</p>
                  <p class="mt-3 text-xs font-medium text-brand">{primaryKeyword}</p>
                  <span class="mt-3 text-sm font-semibold text-brand">ดูรายละเอียด →</span>
                </div>
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</section>
