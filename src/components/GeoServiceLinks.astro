---
import { districts } from '../lib/districts';
import { areaPath } from '../config/urls';

interface Props {
  serviceLabel: string;
}

const { serviceLabel } = Astro.props;
---

<section class="bg-surface-alt py-12 sm:py-14" aria-labelledby="geo-service-heading">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <h2 id="geo-service-heading" class="text-xl font-bold text-ink sm:text-2xl">
      พื้นที่รับซื้อด่วน — {serviceLabel}
    </h2>
    <p class="mt-2 text-muted">นัดรับถึงที่ในอำเภอต่างๆ ทั่วอุบลราชธานี — เลือกพื้นที่ของคุณเพื่อดูรายละเอียด</p>
    <ul class="mt-6 flex flex-wrap gap-2">
      {
        districts.map((district) => (
          <li>
            <a
              href={areaPath(district.slug)}
              class="inline-block rounded-full border border-line bg-surface px-4 py-2 text-sm font-medium text-muted transition hover:border-brand/30 hover:text-brand"
            >
              อ.{district.name}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
