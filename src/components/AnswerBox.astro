---
/** กล่องคำตอบสั้น AEO — วางหลัง hero ทันที */
export interface Props {
  question: string;
  answer: string;
}

const { question, answer } = Astro.props;
---

<aside
  class="border-b border-line bg-surface-alt py-8 sm:py-10"
  aria-label="คำตอบสั้น"
  itemscope
  itemtype="https://schema.org/Question"
>
  <div class="mx-auto max-w-3xl px-4 sm:px-6">
    <div class="rounded-2xl border border-brand/20 bg-surface p-5 shadow-sm sm:p-6">
      <p class="text-xs font-semibold uppercase tracking-wide text-brand">คำตอบสั้น</p>
      <h2 class="mt-2 text-lg font-bold text-ink sm:text-xl" itemprop="name">
        {question}
      </h2>
      <div itemprop="acceptedAnswer" itemscope itemtype="https://schema.org/Answer">
        <p class="mt-3 text-sm leading-relaxed text-muted sm:text-base" itemprop="text">
          {answer}
        </p>
      </div>
    </div>
  </div>
</aside>
