---
import { SITE, getLineOALink } from '../config/site';
import { serviceNav, areaNav, mainNav } from '../config/navigation';
import { areasIndex, contactPage, servicesIndex, updatesIndex } from '../config/urls';

const lineLink = getLineOALink();
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-40 border-b border-line/60 bg-surface/95 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-3 sm:px-6">
    <a href="/" class="group flex min-w-0 items-center">
      <img
        src="/images/logo.webp"
        alt={`${SITE.name} โลโก้`}
        width="578"
        height="165"
        class="h-12 w-auto sm:h-14"
        fetchpriority="high"
        decoding="async"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-1 lg:flex" aria-label="เมนูหลัก">
      <a
        href="/"
        class:list={[
          'rounded-lg px-3 py-2 text-sm font-medium transition hover:bg-brand/5 hover:text-brand',
          currentPath === '/' ? 'text-brand' : 'text-muted',
        ]}
      >
        หน้าแรก
      </a>

      <div class="group relative">
        <button
          type="button"
          class="flex items-center gap-1 rounded-lg px-3 py-2 text-sm font-medium text-muted transition hover:bg-brand/5 hover:text-brand"
          aria-haspopup="true"
        >
          บริการรับซื้อ
          <span class="text-xs" aria-hidden="true">▼</span>
        </button>
        <div
          class="invisible absolute left-0 top-full z-50 min-w-[16rem] rounded-xl border border-line bg-surface py-2 opacity-0 shadow-lg transition group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100"
          role="menu"
        >
          {
            serviceNav.map((item) => (
              <a
                href={item.href}
                role="menuitem"
                class:list={[
                  'block px-4 py-2.5 text-sm transition hover:bg-brand/5 hover:text-brand',
                  currentPath.startsWith(item.href) ? 'font-semibold text-brand' : 'text-ink',
                ]}
              >
                {item.label}
              </a>
            ))
          }
          <a
            href={servicesIndex()}
            role="menuitem"
            class="block border-t border-line px-4 py-2.5 text-sm font-semibold text-brand hover:bg-brand/5"
          >
            ดูบริการทั้งหมด →
          </a>
        </div>
      </div>

      <div class="group relative">
        <button
          type="button"
          class="flex items-center gap-1 rounded-lg px-3 py-2 text-sm font-medium text-muted transition hover:bg-brand/5 hover:text-brand"
          aria-haspopup="true"
        >
          พื้นที่ให้บริการด่วน
          <span class="text-xs" aria-hidden="true">▼</span>
        </button>
        <div
          class="invisible absolute left-0 top-full z-50 min-w-[14rem] rounded-xl border border-line bg-surface py-2 opacity-0 shadow-lg transition group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100"
          role="menu"
        >
          {
            areaNav.map((item) => (
              <a
                href={item.href}
                role="menuitem"
                class:list={[
                  'block px-4 py-2.5 text-sm transition hover:bg-brand/5 hover:text-brand',
                  currentPath.startsWith(item.href) ? 'font-semibold text-brand' : 'text-ink',
                ]}
              >
                {item.label}
              </a>
            ))
          }
          <a
            href={areasIndex()}
            role="menuitem"
            class="block border-t border-line px-4 py-2.5 text-sm font-semibold text-brand hover:bg-brand/5"
          >
            ดูพื้นที่ทั้งหมด →
          </a>
        </div>
      </div>

      {
        mainNav
          .filter((item) => item.href !== '/')
          .map((item) => (
            <a
              href={item.href}
              class:list={[
                'rounded-lg px-3 py-2 text-sm font-medium transition hover:bg-brand/5 hover:text-brand',
                currentPath === item.href || currentPath.startsWith(item.href + '/')
                  ? 'text-brand'
                  : 'text-muted',
              ]}
            >
              {item.label}
            </a>
          ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={lineLink}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden items-center gap-2 rounded-full bg-line px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-line-dark focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-line sm:inline-flex"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"
          ></path>
        </svg>
        ประเมินราคาด่วน
      </a>

      <!-- Mobile menu -->
      <details class="relative lg:hidden">
        <summary
          class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-lg border border-line text-ink marker:content-none [&::-webkit-details-marker]:hidden"
          aria-label="เปิดเมนู"
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </summary>
        <nav
          class="absolute right-0 top-full z-50 mt-2 w-72 rounded-xl border border-line bg-surface py-2 shadow-xl"
          aria-label="เมนูมือถือ"
        >
          <a href="/" class="block px-4 py-2.5 text-sm font-medium text-ink hover:bg-brand/5">หน้าแรก</a>
          <p class="px-4 pt-3 text-xs font-semibold uppercase tracking-wide text-muted">บริการรับซื้อ</p>
          {serviceNav.map((item) => (
            <a href={item.href} class="block px-4 py-2 text-sm text-muted hover:bg-brand/5 hover:text-brand">
              {item.label}
            </a>
          ))}
          <p class="px-4 pt-3 text-xs font-semibold uppercase tracking-wide text-muted">พื้นที่ให้บริการ</p>
          {areaNav.map((item) => (
            <a href={item.href} class="block px-4 py-2 text-sm text-muted hover:bg-brand/5 hover:text-brand">
              {item.label}
            </a>
          ))}
          <div class="my-2 border-t border-line"></div>
          <a href={updatesIndex()} class="block px-4 py-2.5 text-sm text-ink hover:bg-brand/5">ผลงานรับซื้อล่าสุด</a>
          <a href={contactPage()} class="block px-4 py-2.5 text-sm text-ink hover:bg-brand/5">ติดต่อเรา</a>
          <div class="p-3">
            <a
              href={lineLink}
              target="_blank"
              rel="noopener noreferrer"
              class="flex w-full items-center justify-center rounded-full bg-line px-4 py-2.5 text-sm font-semibold text-white"
            >
              ประเมินราคาด่วน
            </a>
          </div>
        </nav>
      </details>

      <a
        href={lineLink}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex shrink-0 items-center gap-1 rounded-full bg-line px-3 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-line-dark sm:hidden"
        aria-label="แชท LINE"
      >
        LINE
      </a>
    </div>
  </div>
</header>
