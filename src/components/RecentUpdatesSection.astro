---
import type { CollectionEntry } from 'astro:content';

interface Props {
  examples: CollectionEntry<'examples'>[];
}

const { examples } = Astro.props;
---

<section id="examples" class="bg-surface-alt py-14 sm:py-16">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-center">
      <div>
        <h2 class="text-2xl font-bold text-ink sm:text-3xl">ตัวอย่างเคสประเมินราคา</h2>
        <p class="mt-2 text-muted">ตัวอย่างสถานการณ์ประเมิน (ไม่ใช่ผลงานรับซื้อจริง) เพื่อความโปร่งใส</p>
      </div>
      <a
        href="/ตัวอย่างเคสประเมิน/"
        class="shrink-0 rounded-full border border-brand px-4 py-2 text-sm font-semibold text-brand transition hover:bg-brand hover:text-white"
      >
        ดูทั้งหมด →
      </a>
    </div>

    {
      examples.length > 0 ? (
        <ul class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {examples.slice(0, 3).map((post) => (
            <li>
              <article class="flex h-full flex-col rounded-2xl border border-line bg-surface p-5 shadow-sm transition hover:border-brand/30 hover:shadow-md relative overflow-hidden">
                <div class="absolute top-0 right-0 bg-amber-500 text-white text-xs px-2 py-1 font-semibold rounded-bl-lg">
                  ตัวอย่างเคส
                </div>
                <h3 class="mt-4 text-lg font-bold text-ink">
                  <a href={`/ตัวอย่างเคสประเมิน/${post.data.slug}/`} class="transition hover:text-brand">
                    {post.data.title}
                  </a>
                </h3>
                <p class="mt-2 flex-1 text-sm leading-relaxed text-muted">{post.data.description}</p>
                <a href={`/ตัวอย่างเคสประเมิน/${post.data.slug}/`} class="mt-4 text-sm font-semibold text-brand hover:underline">
                  อ่านต่อ →
                </a>
              </article>
            </li>
          ))}
        </ul>
      ) : (
        <p class="mt-8 text-muted">กำลังอัปเดตตัวอย่างเคส — ติดตามได้เร็วๆ นี้</p>
      )
    }
  </div>
</section>
