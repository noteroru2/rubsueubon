---
import type { CollectionEntry } from 'astro:content';
import { updatePath, updatesIndex } from '../config/urls';

interface Props {
  updates: CollectionEntry<'updates'>[];
}

const { updates } = Astro.props;

function formatDate(date: Date): string {
  return date.toLocaleDateString('th-TH', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<section id="updates" class="bg-surface-alt py-14 sm:py-16">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-center">
      <div>
        <h2 class="text-2xl font-bold text-ink sm:text-3xl">ผลงานรับซื้อล่าสุด</h2>
        <p class="mt-2 text-muted">เคสจริงจากลูกค้าในอุบลราชธานี — ราคาโปร่งใส จ่ายเงินสดทันที</p>
      </div>
      <a
        href={updatesIndex()}
        class="shrink-0 rounded-full border border-brand px-4 py-2 text-sm font-semibold text-brand transition hover:bg-brand hover:text-white"
      >
        ดูทั้งหมด →
      </a>
    </div>

    {
      updates.length > 0 ? (
        <ul class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {updates.map((post) => (
            <li>
              <article class="flex h-full flex-col rounded-2xl border border-line bg-surface p-5 shadow-sm transition hover:border-brand/30 hover:shadow-md">
                <time datetime={post.data.pubDate.toISOString()} class="text-xs font-medium text-brand">
                  {formatDate(post.data.pubDate)}
                </time>
                <h3 class="mt-2 text-lg font-bold text-ink">
                  <a href={updatePath(post.data.slug)} class="transition hover:text-brand">
                    {post.data.title}
                  </a>
                </h3>
                <p class="mt-2 flex-1 text-sm leading-relaxed text-muted">{post.data.description}</p>
                <a
                  href={updatePath(post.data.slug)}
                  class="mt-4 text-sm font-semibold text-brand hover:underline"
                >
                  อ่านต่อ →
                </a>
              </article>
            </li>
          ))}
        </ul>
      ) : (
        <p class="mt-8 text-muted">กำลังอัปเดตผลงานรับซื้อ — ติดตามได้เร็วๆ นี้</p>
      )
    }
  </div>
</section>
