---
import { serviceClusters } from '../config/home-hub';
---

<section id="service-clusters" class="border-t border-line bg-surface-alt py-14 sm:py-16">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-2xl font-bold text-ink sm:text-3xl">บริการรับซื้อตามหมวดสินค้า</h2>
      <p class="mt-3 text-muted">เลือกหมวดที่ตรงกับสินค้าของคุณ — ลิงก์ไปหน้าบริการและรุ่นยอดนิยมในอุบลราชธานี</p>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2">
      {
        serviceClusters.map((cluster) => (
          <article class="rounded-2xl border border-line bg-surface p-6 shadow-sm">
            <h3 class="text-lg font-bold text-ink">{cluster.title}</h3>
            <ul class="mt-4 flex flex-wrap gap-2">
              {cluster.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="inline-block rounded-full border border-line bg-surface-alt px-3 py-1.5 text-sm text-muted transition hover:border-brand/40 hover:bg-brand/5 hover:text-brand"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>
