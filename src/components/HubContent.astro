---
import { serviceNav } from '../config/navigation';
import { areasIndex, updatesIndex, servicePath, areaPath } from '../config/urls';

const LINE_URL = 'https://line.me/R/ti/p/@buyhub';
---

<div class="divide-y divide-line">
  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- H2 §1 — ภาพรวมบริการ                                  -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <section class="py-14 sm:py-16" aria-labelledby="hub-overview">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <h2 id="hub-overview" class="text-2xl font-bold text-ink sm:text-3xl">
        รับซื้อ-รับเทิร์นไอที อุบลราชธานี — ศูนย์กลางครบวงจร จ่ายเงินสดให้ราคาอิงราคาตลาด
      </h2>

      <div
        class="prose prose-lg mt-6 max-w-none prose-p:text-muted prose-strong:text-ink prose-a:text-brand prose-a:no-underline hover:prose-a:underline"
      >
        <p>
          ชาวอุบลราชธานีและพื้นที่ใกล้เคียงฟังทางนี้! หากคุณกำลังมองหาร้าน <strong>รับซื้อไอที</strong> ที่ไว้ใจได้ ตีราคาแฟร์แบบไม่กดราคาหน้างาน
          <strong>รับซื้ออุบล.com</strong> คือคำตอบสุดท้ายของคุณครับ เราคือแพลตฟอร์มรับซื้อและรับเทิร์นสินค้าไอทีมือหนึ่ง-มือสองในจังหวัดอุบลราชธานีที่ออกแบบมาเพื่อตัดปัญหาจุกจิกทั้งหมด
        </p>

        <p>
          ไม่ต้องทนโพสต์ขายเองแล้วเจอคนต่อราคาแบบไร้เยื่อใย ไม่ต้องกลัวนัดแล้วโดนเท เราพร้อมรับจบทุกเคส ครอบคลุมทั้ง <strong
            >สมาร์ทโฟน โน้ตบุ๊ก กล้อง แท็บเล็ต อุปกรณ์ Apple เครื่องเกมคอนโซล</strong
          > และแก็ดเจ็ตไอทีอื่นๆ ทุกขั้นตอนโปร่งใส ประเมินราคาผ่าน LINE ภายใน 5 นาทีรู้ผลทันที!
        </p>

        <div class="my-8 rounded-2xl border-l-4 border-brand bg-brand/5 p-6 shadow-sm">
          <div class="flex items-center gap-3">
            <span class="text-2xl">🔥</span>
            <strong class="text-lg text-brand">พร้อมเปลี่ยนเครื่องเก่าเป็นเงินก้อนโตแล้วหรือยัง?</strong>
          </div>
          <p class="mt-3 text-ink">
            อย่าปล่อยให้สินค้าไอทีของคุณมูลค่าลดลงทุกวัน ทักมาประเมินราคาฟรีตอนนี้เลย! ตีราคาไวใน 5 นาที รับเงินสดทันที
          </p>
          <p class="mt-4">
            <a href={LINE_URL} class="inline-flex items-center font-bold text-brand hover:underline">
              👉 คลิกที่นี่เพื่อส่งรูปประเมินราคาผ่าน LINE @buyhub
            </a>
          </p>
        </div>

        <h3>บริการรับซื้อที่เราพร้อมเปย์หนัก</h3>
        <p>
          เรารองรับสินค้าไอทีหลากหลายประเภท แต่ละหมวดมีผู้เชี่ยวชาญที่เข้าใจมูลค่าตลาดโดยตรง
          ทำให้ประเมินราคาได้ประเมินตามสภาพ
        </p>
        <ul>
          {
            serviceNav.map((item) => (
              <li>
                <a href={item.href}>{item.label}</a>
              </li>
            ))
          }
        </ul>

        <h4>วิธีเริ่มต้นขายสินค้าไอทีให้จบไวในวันเดียว</h4>
        <p>
          เพียงแอด LINE <strong>@buyhub</strong> ถ่ายรูปสินค้าพร้อมแจ้งรุ่นและสภาพ เราจะตอบกลับพร้อมใบเสนอราคาที่สูงที่สุดที่เราสู้ไหว
          ไม่มีข้อผูกมัด ไม่ต้องตัดสินใจทันที เมื่อตกลงราคาแล้วค่อยนัดรับสินค้าในอุบลราชธานีเพื่อรับเงินสดกลับบ้าน
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- H2 §2 — รับซื้อโทรศัพท์มือถือ                        -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <section class="py-14 sm:py-16" aria-labelledby="hub-smartphone">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <h2 id="hub-smartphone" class="text-2xl font-bold text-ink sm:text-3xl">
        รับซื้อโทรศัพท์มือถือ อุบลราชธานี ให้ราคาน่าเชื่อถือในย่านนี้
      </h2>

      <div
        class="prose prose-lg mt-6 max-w-none prose-p:text-muted prose-strong:text-ink prose-a:text-brand prose-a:no-underline hover:prose-a:underline"
      >
        <p>
          โทรศัพท์มือถือเป็นอวัยวะชิ้นที่ 33 ของทุกคน เมื่อถึงเวลาอัปเกรดรุ่นใหม่
          เครื่องเก่าก็ไม่ควรเก็บไว้ให้แบตเสื่อมเปล่าๆ นำมาขายกับเรา เรารับจบหมดตั้งแต่ iPhone รุ่นฮิตไปจนถึง Android
          แบรนด์ดัง ตีราคาตามสภาพจริงและราคาตลาดปัจจุบันแบบเรียลไทม์
        </p>

        <h3>รับซื้อ iPhone ทุกรุ่น ซีรีส์ไหนก็ให้ราคางาม</h3>
        <p>
          iPhone เป็นสมาร์ทโฟนที่ราคาแข็งที่สุด เราเชี่ยวชาญในการประเมินราคาตั้งแต่ iPhone 11 จนถึง 15 Pro Max
          โดยพิจารณาจากความจุ สภาพแบตเตอรี่ และอุปกรณ์เสริม หากคุณมีครบกล่อง เรายินดีบวกราคาเพิ่มให้แบบจุกๆ
          ดูรายละเอียดที่ <a href={servicePath('iphone-ubon')}>รับซื้อ iPhone อุบล</a>
        </p>

        <h4>เคล็ดลับเพิ่มราคา iPhone ให้ได้ราคายุติธรรมและคุ้มค่า</h4>
        <p>
          ราคาจะแปรผันตามรุ่น ความจุ และสุขภาพแบตเตอรี่ (Battery Health) เพื่อความรวดเร็ว แนะนำให้ถ่ายรูปหน้าตั้งค่า
          &gt; ทั่วไป &gt; เกี่ยวกับ และหน้าสุขภาพแบตเตอรี่ส่งมาให้เราดู เพื่อให้การประเมินราคาอิงตามสภาพจริงและน่าพึงพอใจ
        </p>

        <h3>รับซื้อ Samsung Galaxy และ Android ทุกแบรนด์</h3>
        <p>
          เราเป็นแฟนตัวยงของ <a href={servicePath('samsung-ubon')}>Samsung Galaxy</a> ครอบคลุมทั้ง S series, Z Fold/Flip,
          A series และแท็บเล็ต Tab S นอกจากนี้เรายังรับซื้อ OPPO, vivo, Xiaomi และแบรนด์ชั้นนำอื่นๆ สนใจดูรายละเอียดเพิ่มเติมได้ที่
          <a href={servicePath('smartphone-ubon')}>รับซื้อโทรศัพท์ อุบล</a>
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- H2 §3 — รับซื้อโน้ตบุ๊กและคอมพิวเตอร์               -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <section class="py-14 sm:py-16" aria-labelledby="hub-notebook">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <h2 id="hub-notebook" class="text-2xl font-bold text-ink sm:text-3xl">
        รับซื้อโน้ตบุ๊ก คอมพิวเตอร์ และ PC Gaming อุบลราชธานี ตีราคาเจาะลึก
      </h2>

      <div
        class="prose prose-lg mt-6 max-w-none prose-p:text-muted prose-strong:text-ink prose-a:text-brand prose-a:no-underline hover:prose-a:underline"
      >
        <p>
          ตลาดโน้ตบุ๊กและคอมพิวเตอร์มีความซับซ้อน ร้านทั่วไปมักตีราคาเหมาๆ จนทำให้เครื่องสเปคเทพของคุณราคาตกฮวบ!
          แต่ที่นี่ เรามีผู้เชี่ยวชาญที่ประเมินชิ้นส่วนฮาร์ดแวร์โดยเฉพาะ ไม่ว่าจะเป็นการ์ดจอรุ่นท็อปหรือ CPU ตัวแรง
          เราให้ราคาตามมูลค่าจริงอย่างยุติธรรม
        </p>

        <h3>รับซื้อ MacBook และโน้ตบุ๊กทุกค่าย</h3>
        <p>
          <a href={servicePath('macbook-ubon')}>MacBook Air และ Pro</a> (ชิป M1-M3 หรือ Intel) ไปจนถึงโน้ตบุ๊กเกมมิ่งสายแข็ง
          (ASUS ROG, Acer Predator, Lenovo Legion, MSI) แม้แบตจะเสื่อมหรือจอมีรอย เราก็ตีราคาให้อย่างสมเหตุสมผล
        </p>

        <h3>รับซื้อ PC Gaming และเครื่องประกอบ</h3>
        <p>
          เครื่องคอมพิวเตอร์ประกอบ <a href={servicePath('pc-gaming-ubon')}>PC Gaming</a> สเปคเทพแค่ไหนเราก็พร้อมรับ เราเข้าใจมูลค่าที่แท้จริงของการ์ดจอ
          RTX หรือ RX ซีรีส์ล่าสุด
        </p>

        <div class="my-8 rounded-2xl border border-line bg-surface p-6 shadow-sm">
          <strong class="text-lg text-ink">💡 รู้อย่างนี้ขายไปนานแล้ว!</strong>
          <p class="mt-2 text-muted">
            นัดรับถึงที่ จ่ายเงินสดโอนเข้าบัญชีเต็มจำนวน ไม่มีหักค่าธรรมเนียม ลบข้อมูลให้ฟรีต่อหน้า 100% ปลอดภัยชัวร์
          </p>
          <p class="mt-4">
            <a href={LINE_URL} class="inline-flex items-center font-bold text-brand hover:underline">
              📲 ทักแชท LINE: @buyhub เพื่อคุยรายละเอียดได้เลย
            </a>
          </p>
        </div>

        <h4>รับซื้อการ์ดจอ CPU และอะไหล่แยกชิ้น</h4>
        <p>
          ไม่อยากขายยกเครื่อง? ไม่มีปัญหา! เรารับซื้อ <a href={servicePath('pc-parts-ubon')}
            >การ์ดจอแยก, CPU, RAM และ SSD</a
          > เพียงแค่ส่งสเปคมาให้เราประเมิน
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- H2 §4 — รับซื้ออุปกรณ์ Apple                         -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <section class="py-14 sm:py-16" aria-labelledby="hub-apple">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <h2 id="hub-apple" class="text-2xl font-bold text-ink sm:text-3xl">รับซื้ออุปกรณ์ Apple ทุกชนิด มูลค่าไม่ตก</h2>

      <div
        class="prose prose-lg mt-6 max-w-none prose-p:text-muted prose-strong:text-ink prose-a:text-brand prose-a:no-underline hover:prose-a:underline"
      >
        <p>
          สาวก Apple ห้ามพลาด! เรารู้ดีว่าสินค้าใน Apple Ecosystem มีดีมานด์สูงมากในตลาดมือสอง
          เราจึงกล้าให้ราคารับซื้อที่สูงปรี๊ด ไม่ว่าจะเป็น MacBook, iPad, Apple Watch หรือ AirPods
        </p>

        <h3>รับซื้อ iPad และแท็บเล็ตไฮเอนด์</h3>
        <p>
          <a href={servicePath('ipad-ubon')}>iPad Pro, iPad Air, iPad mini, iPad Gen</a> รวมถึงอุปกรณ์เสริมอย่าง Magic Keyboard
          หรือ Apple Pencil ยิ่งมาเป็นคู่ยิ่งได้ราคาดี
        </p>

        <h4>Apple Watch และ AirPods</h4>
        <p>
          สำหรับ <a href={servicePath('smartwatch-ubon')}>Apple Watch</a> และ AirPods ขอเพียงแค่คุณ Unpair และนำออกจาก iCloud
          (Find My) ล่วงหน้า ก็พร้อมรับเงินสดได้เลยทันที
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- H2 §5 — รับซื้อกล้อง                                 -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <section class="py-14 sm:py-16" aria-labelledby="hub-camera">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <h2 id="hub-camera" class="text-2xl font-bold text-ink sm:text-3xl">รับซื้อกล้องและเลนส์มือสอง สายแชะมาทางนี้</h2>

      <div
        class="prose prose-lg mt-6 max-w-none prose-p:text-muted prose-strong:text-ink prose-a:text-brand prose-a:no-underline hover:prose-a:underline"
      >
        <p>
          วางกล้องให้ฝุ่นเกาะทำไม? เปลี่ยนเป็นเงินก้อนไปต่อยอดดีกว่า เรารับซื้อกล้อง Mirrorless และ DSLR มือสองทุกค่าย
          ตีราคาอย่างมืออาชีพเช็ค Shutter Count ให้ดูต่อหน้า
        </p>

        <h3>รับซื้อกล้อง Sony แบรนด์ยอดฮิต</h3>
        <p>
          <a href={servicePath('sony-camera-ubon')}>กล้อง Sony Alpha</a> (A7III, A7IV, A7C, ZV-E10) และตระกูลเลนส์ G Master
          คือสินค้าที่เราให้ราคาพรีเมียม
        </p>

        <h3>รับซื้อ Canon, Nikon, Fujifilm ครบจบ</h3>
        <p>
          รวมไปถึงค่ายอื่นๆ อย่าง <a href={servicePath('camera-ubon')}>Canon EOS R, Nikon Z, Fujifilm X series</a> ทั้งตัวบอดี้เปล่าๆ
          หรือจะมัดรวมเลนส์มาขายเราก็สู้ราคาครับ
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- H2 §6 — รับซื้อเครื่องเกมและแก็ดเจ็ต                -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <section class="py-14 sm:py-16" aria-labelledby="hub-gaming">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <h2 id="hub-gaming" class="text-2xl font-bold text-ink sm:text-3xl">
        รับซื้อเครื่องเกมและลำโพงแบรนด์ดัง เปลี่ยนของเล่นเป็นทุน
      </h2>

      <div
        class="prose prose-lg mt-6 max-w-none prose-p:text-muted prose-strong:text-ink prose-a:text-brand prose-a:no-underline hover:prose-a:underline"
      >
        <p>
          สายเกมเมอร์หรือสายปาร์ตี้ที่อยากปล่อยของ เราก็รับซื้อ! เครื่องเล่นเกมคอนโซล
          หรือลำโพงบลูทูธพรีเมียมก็ขายได้ราคาดีกว่าที่คุณคิด
        </p>

        <h3>รับซื้อ PS5 และ Nintendo Switch</h3>
        <p>
          <a href={servicePath('game-console-ubon')}>PlayStation 5, Nintendo Switch (OLED)</a> ถ้ามีแผ่นเกมหรืออุปกรณ์เสริมมาด้วย
          เราประเมินเพิ่มให้ทุกชิ้น ไม่มีหัก
        </p>

        <h4>ลำโพง Marshall, JBL, Harman Kardon</h4>
        <p>
          เปลี่ยนเครื่องเสียงตัวโปรดของคุณให้กลายเป็นเงินสดได้ที่นี่ ดูรายละเอียดเพิ่มเติม <a
            href={servicePath('speaker-ubon')}>รับซื้อเครื่องเสียง อุบล</a
          >
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- H2 §7 — พื้นที่ให้บริการ                             -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <section class="py-14 sm:py-16" aria-labelledby="hub-areas">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <h2 id="hub-areas" class="text-2xl font-bold text-ink sm:text-3xl">
        พื้นที่บริการรับซื้อ วิ่งไปหาถึงที่ทั่วอุบล
      </h2>

      <div
        class="prose prose-lg mt-6 max-w-none prose-p:text-muted prose-strong:text-ink prose-a:text-brand prose-a:no-underline hover:prose-a:underline"
      >
        <p>
          เราให้บริการคลอบคลุมทุกพื้นที่ในจังหวัดอุบลราชธานี คุณไม่จำเป็นต้องฝ่ารถติดเข้าเมืองมาหาเรา เพราะเรามี <strong
            >"บริการรับสินค้าถึงหน้าบ้าน"</strong
          > นัดง่าย ตรงเวลา และปลอดภัย
        </p>

        <h3>อำเภอหลักที่ให้บริการด่วนพิเศษ</h3>
        <ul>
          <li>
            <a href={areaPath('mueang-ubon')}>เมืองอุบลราชธานี</a> — ม.อุบล, เซ็นทรัล, ตลาดนัดจัสมอล
          </li>
          <li><a href={areaPath('warin-chamrap')}>วารินชำราบ</a> — ตลาดเจริญศรี, ใกล้สะพานมุกดาหาร</li>
